.calendar-card {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 28rpx rgba(24, 139, 228, 0.08);
}

.calendar-head {
  height: 104rpx;
  padding: 0 24rpx;
  background: #188be4;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.month-nav {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
}

.month-title {
  font-size: 34rpx;
  font-weight: 700;
  white-space: nowrap;
}

.month-arrow {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  line-height: 1;
}

.records-btn {
  flex-shrink: 0;
  height: 56rpx;
  padding: 0 18rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.32);
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  white-space: nowrap;
}

.records-icon {
  font-size: 26rpx;
  transform: translateY(-1rpx);
}

.week-row,
.day-grid-inner {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
}

.week-row {
  padding: 18rpx 18rpx 4rpx;
}

.week-cell {
  text-align: center;
  color: #7d8790;
  font-size: 25rpx;
}

.day-grid {
  padding: 4rpx 18rpx 8rpx;
  overflow: hidden;
  transition: max-height 0.24s ease;
}

.day-grid-inner {
  transition: transform 0.24s ease;
  will-change: transform;
}

.day-grid-week {
  max-height: 102rpx;
}

.day-grid-month {
  max-height: 600rpx;
  padding-bottom: 6rpx;
}

.day-cell {
  height: 98rpx;
  box-sizing: border-box;
  padding-top: 10rpx;
  text-align: center;
  border-radius: 14rpx;
}

.day-cell-empty {
  opacity: 0;
}

.day-cell-outside {
  opacity: 0.36;
}

.day-cell-outside .day-number {
  color: #9facb8;
}

.day-number {
  width: 44rpx;
  height: 44rpx;
  margin: 0 auto;
  border-radius: 22rpx;
  line-height: 44rpx;
  color: #333f4a;
  font-size: 27rpx;
}

.day-cell-today .day-number {
  background: #e8f4ff;
  color: #188be4;
  font-weight: 700;
}

.day-cell-selected .day-number {
  background: #188be4;
  color: #ffffff;
}

.day-weight {
  margin-top: 4rpx;
  color: #5f86a8;
  font-size: 22rpx;
  line-height: 26rpx;
  font-weight: 700;
}
