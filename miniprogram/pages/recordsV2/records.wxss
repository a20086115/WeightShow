page {
  background: #f4f7fb;
  color: #172033;
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  box-sizing: border-box;
}

.month-panel,
.trend-card,
.summary-card,
.empty-card,
.timeline-card {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 16rpx 42rpx rgba(31, 54, 86, 0.08);
}

.month-panel {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 18rpx;
}

.month-arrow {
  width: 76rpx;
  height: 76rpx;
  padding: 0;
  border-radius: 38rpx;
  background: #edf6ff;
  color: #188be4;
  font-size: 52rpx;
  line-height: 72rpx;
}

.month-arrow.disabled {
  opacity: 0;
}

.month-arrow::after,
.record-delete-button::after,
.primary-action::after,
.secondary-action::after {
  border: 0;
}

.month-center {
  text-align: center;
}

.month-title {
  font-size: 36rpx;
  font-weight: 700;
}

.month-subtitle,
.section-subtitle,
.empty-text,
.dialog-subtitle {
  margin-top: 6rpx;
  color: #7a8799;
  font-size: 24rpx;
}

.scope-tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  padding: 8rpx;
  border-radius: 20rpx;
  background: #eaf1f8;
}

.top-tabs {
  margin-top: 0;
}

.scope-tab {
  height: 64rpx;
  border-radius: 16rpx;
  color: #627086;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 64rpx;
  text-align: center;
}

.scope-tab.active {
  background: #fff;
  color: #188be4;
  box-shadow: 0 8rpx 22rpx rgba(31, 54, 86, 0.08);
}

.summary-card {
  margin-top: 22rpx;
  padding: 28rpx;
}

.trend-card {
  margin-top: 22rpx;
  padding: 28rpx;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.granularity-tabs {
  display: flex;
  flex-shrink: 0;
  padding: 6rpx;
  border-radius: 16rpx;
  background: #edf3f8;
}

.granularity-tab {
  min-width: 72rpx;
  height: 48rpx;
  padding: 0 12rpx;
  border-radius: 12rpx;
  color: #627086;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 48rpx;
  text-align: center;
}

.granularity-tab.active {
  background: #fff;
  color: #188be4;
  box-shadow: 0 6rpx 16rpx rgba(31, 54, 86, 0.08);
}

.chart-box {
  height: 360rpx;
  margin-top: 18rpx;
}

.chart-box ec-canvas {
  width: 100%;
  height: 100%;
}

.chart-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 220rpx;
  margin-top: 18rpx;
  border-radius: 18rpx;
  background: #f6f8fb;
  color: #7a8799;
  font-size: 26rpx;
}

.summary-main {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.summary-label {
  color: #7a8799;
  font-size: 24rpx;
}

.summary-value {
  margin-top: 8rpx;
  color: #172033;
  font-size: 44rpx;
  font-weight: 800;
}

.summary-note {
  margin-top: 6rpx;
  color: #7a8799;
  font-size: 24rpx;
}

.summary-value.down,
.change-chip.down {
  color: #12a66a;
}

.summary-value.up,
.change-chip.up {
  color: #ff6470;
}

.summary-badge {
  max-width: 250rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #edf8f2;
  color: #12a66a;
  font-size: 24rpx;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 26rpx;
}

.summary-item {
  padding: 20rpx 12rpx;
  border-radius: 18rpx;
  background: #f6f8fb;
  text-align: center;
}

.summary-item text {
  display: block;
}

.summary-item text:first-child {
  color: #172033;
  font-size: 30rpx;
  font-weight: 700;
}

.summary-item text:last-child {
  margin-top: 6rpx;
  color: #7a8799;
  font-size: 22rpx;
}

.list-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 20rpx;
  margin: 34rpx 4rpx 18rpx;
}

.record-filter-bar {
  min-height: 64rpx;
  margin: -4rpx 4rpx 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.archive-filter-bar {
  margin-top: -8rpx;
}

.photo-filter-tabs {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 6rpx;
  border-radius: 999rpx;
  background: #eaf1f8;
}

.photo-filter-tab {
  min-width: 108rpx;
  height: 50rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  color: #627086;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 50rpx;
  text-align: center;
  box-sizing: border-box;
}

.photo-filter-tab.active {
  background: #ffffff;
  color: #188be4;
  box-shadow: 0 6rpx 18rpx rgba(31, 54, 86, 0.08);
}

.record-image-toggle.subtle {
  min-width: 0;
  height: 58rpx;
  padding: 0 0 0 14rpx;
  border-radius: 999rpx;
  background: transparent;
  color: #7a8799;
}

.record-image-toggle.subtle switch {
  flex-shrink: 0;
  transform: scale(0.68);
  transform-origin: right center;
}

.list-head .record-image-toggle {
  display: none;
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
}

.record-image-toggle {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #657381;
  font-size: 23rpx;
  font-weight: 700;
}

.record-image-toggle switch {
  transform: scale(0.72);
  transform-origin: right center;
}

.empty-card {
  padding: 52rpx 34rpx;
  text-align: center;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 700;
}

.timeline-list {
  position: relative;
  margin-top: 16rpx;
  padding-left: 64rpx;
}

.timeline-line {
  position: absolute;
  top: 24rpx;
  bottom: 34rpx;
  left: 26rpx;
  width: 4rpx;
  border-radius: 999rpx;
  background: #0f73ff;
}

.timeline-item {
  position: relative;
  margin-bottom: 18rpx;
}

.timeline-dot {
  position: absolute;
  top: 40rpx;
  left: -50rpx;
  width: 24rpx;
  height: 24rpx;
  border: 6rpx solid #0f73ff;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 0 0 7rpx #edf5ff;
}

.archive-head {
  margin-top: 34rpx;
}

.year-group {
  margin-top: 16rpx;
}

.year-title {
  margin: 24rpx 4rpx 14rpx;
  color: #172033;
  font-size: 30rpx;
  font-weight: 800;
}

.month-row {
  display: grid;
  grid-template-columns: 112rpx 1fr 136rpx;
  align-items: center;
  gap: 18rpx;
  min-height: 112rpx;
  margin-top: 14rpx;
  padding: 20rpx 22rpx;
  border-radius: 22rpx;
  background: #fff;
  box-shadow: 0 12rpx 34rpx rgba(31, 54, 86, 0.07);
  box-sizing: border-box;
}

.month-name {
  color: #172033;
  font-size: 32rpx;
  font-weight: 800;
}

.month-info {
  color: #7a8799;
  font-size: 24rpx;
  line-height: 1.55;
}

.month-change {
  color: #172033;
  font-size: 28rpx;
  font-weight: 800;
  text-align: right;
}

.timeline-card {
  min-height: 168rpx;
  padding: 22rpx 22rpx 18rpx;
  box-sizing: border-box;
}

.archive-expanded-records {
  grid-column: 1 / -1;
  position: relative;
  margin-top: 14rpx;
  padding: 16rpx 0 2rpx 44rpx;
  border-top: 1rpx solid #eef2f7;
}

.archive-expanded-records::before {
  position: absolute;
  top: 28rpx;
  bottom: 24rpx;
  left: 14rpx;
  width: 3rpx;
  border-radius: 999rpx;
  background: #cfe3ff;
  content: '';
}

.archive-timeline-item {
  position: relative;
  margin-bottom: 16rpx;
}

.archive-timeline-dot {
  position: absolute;
  top: 36rpx;
  left: -38rpx;
  width: 18rpx;
  height: 18rpx;
  border: 5rpx solid #188be4;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 0 0 5rpx #edf5ff;
}

.archive-record-card {
  min-height: 0;
  padding: 20rpx 20rpx 16rpx;
  border-radius: 18rpx;
  box-shadow: 0 8rpx 22rpx rgba(31, 54, 86, 0.06);
}

.archive-empty-records {
  padding: 20rpx 0 8rpx;
  color: #94a3b8;
  font-size: 24rpx;
  text-align: center;
}

.timeline-card-head,
.timeline-card-body,
.timeline-date,
.record-tags {
  display: flex;
  align-items: center;
}

.timeline-card-head {
  justify-content: space-between;
}

.timeline-card-tools {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.record-delete-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 64rpx;
  height: 40rpx;
  margin: 0;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #f5f7fb;
  color: #8b98aa;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 1;
}

.timeline-date {
  gap: 14rpx;
}

.timeline-date-main {
  color: #10192f;
  font-size: 30rpx;
  font-weight: 800;
}

.timeline-weekday {
  color: #10192f;
  font-size: 27rpx;
  font-weight: 700;
}

.timeline-weekday.today {
  color: #0f73ff;
}

.timeline-arrow {
  color: #9aa6ba;
  font-size: 42rpx;
  line-height: 1;
}

.timeline-card-body {
  justify-content: space-between;
  margin-top: 12rpx;
}

.timeline-weight {
  flex: 1;
  min-width: 0;
}

.record-weight {
  color: #10192f;
  font-size: 46rpx;
  font-weight: 900;
}

.unit {
  margin-left: 8rpx;
  color: #10192f;
  font-size: 26rpx;
}

.weight-kg {
  margin-top: 0;
  color: #6f7b92;
  font-size: 24rpx;
}

.body-divider {
  width: 1rpx;
  height: 68rpx;
  margin: 0 26rpx;
  background: #e4ebf5;
}

.timeline-change {
  width: 166rpx;
}

.change-label {
  color: #6f7b92;
  font-size: 23rpx;
}

.change-value {
  margin-top: 4rpx;
  color: #10192f;
  font-size: 38rpx;
  font-weight: 900;
}

.change-value.down {
  color: #11a85d;
}

.change-value.up {
  color: #ff4055;
}

.record-tags {
  flex-wrap: nowrap;
  gap: 8rpx;
  min-width: 0;
  margin-top: 8rpx;
  overflow: hidden;
}

.record-tag {
  flex-shrink: 0;
  max-width: 128rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: #f1f6ff;
  color: #4a7fc8;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-tag.sport {
  background: #eff9f4;
  color: #3b9a6c;
}

.record-tag.warn {
  background: #fff6ec;
  color: #c78120;
}

.record-tag.more {
  max-width: none;
  background: #f3f5f8;
  color: #8a96a8;
}

.record-note {
  display: -webkit-box;
  margin-top: 10rpx;
  padding-top: 10rpx;
  border-top: 1rpx solid #eef2f7;
  color: #748094;
  font-size: 23rpx;
  line-height: 1.45;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
}

.record-image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-top: 14rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #eef2f7;
}

.record-image-thumb {
  display: block;
  width: 100%;
  height: 136rpx;
  border-radius: 12rpx;
  background: #eef2f7;
}

.dialog-mask {
  position: fixed;
  z-index: 10;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  background: rgba(18, 28, 42, 0.48);
}

.dialog-card {
  width: 100%;
  padding: 38rpx 34rpx 52rpx;
  border-radius: 32rpx 32rpx 0 0;
  background: #fff;
  box-sizing: border-box;
}

.dialog-title {
  font-size: 36rpx;
  font-weight: 800;
}

.form-row {
  display: flex;
  align-items: center;
  margin-top: 28rpx;
  padding: 22rpx 24rpx;
  border-radius: 18rpx;
  background: #f6f8fb;
}

.form-row text {
  width: 140rpx;
  color: #596579;
  font-size: 26rpx;
}

.form-row input {
  flex: 1;
  font-size: 30rpx;
}

.primary-action,
.secondary-action {
  width: 100%;
  height: 88rpx;
  margin-top: 26rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 88rpx;
}

.primary-action {
  background: linear-gradient(135deg, #188be4, #1fb9a5);
  color: #fff;
}

.secondary-action {
  background: #f1f4f8;
  color: #596579;
}
