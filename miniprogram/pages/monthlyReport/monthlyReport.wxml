<view class="page">
  <view class="hero-card">
    <view class="hero-kicker">{{monthLabel}} · {{reportSourceText}}</view>
    <view class="hero-title">{{report.overview.title}}</view>
    <view class="hero-desc">{{report.overview.summary}}</view>
    <view class="hero-meta">
      <text>{{report.overview.tag}}</text>
      <text>评分 {{report.overview.score}}</text>
    </view>
  </view>

  <view class="result-grid">
    <view class="result-card">
      <text>{{report.display.days}}</text>
      <text>打卡天数</text>
    </view>
    <view class="result-card">
      <text class="{{report.display.changeClass}}">{{report.display.changeText}}</text>
      <text>体重变化</text>
    </view>
    <view class="result-card">
      <text>{{report.display.latestWeight}}</text>
      <text>最新体重</text>
    </view>
    <view class="result-card">
      <text>{{report.display.targetText}}</text>
      <text>距离目标</text>
    </view>
  </view>

  <view class="section-card">
    <view class="section-title">趋势解读</view>
    <view class="paragraph">{{report.trend.description}}</view>
    <view class="advice-item" wx:for="{{report.trend.highlights}}" wx:key="*this">
      <view class="advice-dot"></view>
      <view>{{item}}</view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-title">打卡习惯</view>
    <view class="paragraph">{{report.habit.summary}}</view>
    <view class="paragraph">{{report.habit.weekdayInsight}}</view>
    <view class="paragraph">{{report.habit.suggestion}}</view>
  </view>

  <view class="section-card">
    <view class="section-title">AI 洞察</view>
    <view class="insight-item {{item.type}}" wx:for="{{report.insights}}" wx:key="title">
      <view class="insight-title">{{item.title}}</view>
      <view class="insight-content">{{item.content}}</view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-title">下月行动</view>
    <view class="advice-item" wx:for="{{report.nextActions}}" wx:key="*this">
      <view class="advice-dot"></view>
      <view>{{item}}</view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-title">给自己的鼓励</view>
    <view class="quote">{{report.encouragement}}</view>
  </view>

  <button class="share-button" open-type="share">分享给朋友</button>
  <button class="refresh-button" wx:if="{{!isSharedReport}}" bindtap="regenerateReport">重新生成</button>
  <view class="timeline-tip">右上角菜单可分享到朋友圈</view>
</view>
