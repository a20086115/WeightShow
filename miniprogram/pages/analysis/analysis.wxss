page {
  background: #f4f7fb;
  color: #172033;
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 56rpx;
  box-sizing: border-box;
}

.month-panel,
.report-entry,
.score-card,
.metric-card,
.chart-card,
.habit-card,
.insight-card {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 16rpx 42rpx rgba(31, 54, 86, 0.08);
}

.month-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 18rpx;
}

.month-arrow {
  width: 76rpx;
  height: 76rpx;
  padding: 0;
  border-radius: 38rpx;
  background: #edf6ff;
  color: #188be4;
  font-size: 52rpx;
  line-height: 72rpx;
}

.month-arrow::after,
.entry-button::after {
  border: 0;
}

.month-center {
  text-align: center;
}

.month-title {
  font-size: 36rpx;
  font-weight: 800;
}

.month-subtitle,
.entry-subtitle,
.score-desc,
.section-subtitle {
  margin-top: 6rpx;
  color: #7a8799;
  font-size: 24rpx;
}

.report-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 22rpx;
  padding: 26rpx 28rpx;
}

.entry-title {
  font-size: 32rpx;
  font-weight: 800;
}

.entry-button {
  width: 144rpx;
  height: 68rpx;
  margin: 0;
  border-radius: 34rpx;
  background: linear-gradient(135deg, #188be4, #1fb9a5);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 68rpx;
}

.score-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 22rpx;
  padding: 30rpx;
}

.score-label {
  color: #7a8799;
  font-size: 24rpx;
}

.score-title {
  margin-top: 8rpx;
  font-size: 38rpx;
  font-weight: 800;
}

.score-left {
  flex: 1;
  min-width: 0;
  padding-right: 24rpx;
}

.score-ring {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 142rpx;
  height: 142rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #188be4, #1fb9a5);
  color: #fff;
}

.score-ring text:first-child {
  font-size: 42rpx;
  font-weight: 800;
}

.score-ring text:last-child {
  font-size: 22rpx;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  margin-top: 22rpx;
}

.metric-card {
  padding: 26rpx;
}

.metric-card text {
  display: block;
}

.metric-card text:first-child {
  font-size: 36rpx;
  font-weight: 800;
}

.metric-card text:last-child {
  margin-top: 8rpx;
  color: #7a8799;
  font-size: 24rpx;
}

.down {
  color: #12a66a;
}

.up {
  color: #ff6470;
}

.chart-card,
.habit-card,
.insight-card {
  margin-top: 22rpx;
  padding: 28rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
}

.chart-box {
  height: 430rpx;
  margin-top: 18rpx;
}

.chart-box ec-canvas {
  width: 100%;
  height: 100%;
}

.chart-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 240rpx;
  color: #7a8799;
  font-size: 26rpx;
}

.weekday-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 24rpx;
}

.weekday-name {
  width: 70rpx;
  color: #596579;
  font-size: 24rpx;
}

.weekday-track {
  flex: 1;
  height: 16rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #ecf1f6;
}

.weekday-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #188be4, #1fb9a5);
}

.weekday-count {
  width: 42rpx;
  text-align: right;
  color: #172033;
  font-size: 24rpx;
  font-weight: 700;
}

.insight-line {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: #f6f8fb;
  color: #344157;
  font-size: 26rpx;
  line-height: 1.55;
}
