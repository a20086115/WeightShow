page {
  background: #f4f7fb;
  color: #172033;
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 56rpx;
  box-sizing: border-box;
}

.month-panel,
.report-entry,
.score-card,
.metric-card,
.chart-card,
.habit-card,
.insight-card {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 16rpx 42rpx rgba(31, 54, 86, 0.08);
}

.scope-tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  padding: 8rpx;
  border-radius: 20rpx;
  background: #eaf1f8;
}

.scope-tab {
  height: 64rpx;
  border-radius: 16rpx;
  color: #627086;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 64rpx;
  text-align: center;
}

.scope-tab.active {
  background: #fff;
  color: #188be4;
  box-shadow: 0 8rpx 22rpx rgba(31, 54, 86, 0.08);
}

.month-panel {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 18rpx;
}

.month-arrow {
  width: 76rpx;
  height: 76rpx;
  padding: 0;
  border-radius: 38rpx;
  background: #edf6ff;
  color: #188be4;
  font-size: 52rpx;
  line-height: 72rpx;
}

.month-arrow.disabled {
  opacity: 0;
}

.month-arrow::after,
.entry-button::after {
  border: 0;
}

.month-center {
  text-align: center;
}

.month-title {
  font-size: 36rpx;
  font-weight: 800;
}

.month-subtitle,
.entry-subtitle,
.score-desc,
.section-subtitle {
  margin-top: 6rpx;
  color: #7a8799;
  font-size: 24rpx;
}

.report-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 22rpx;
  padding: 26rpx 28rpx;
}

.report-entry > view {
  flex: 1;
  min-width: 0;
}

.entry-title {
  font-size: 32rpx;
  font-weight: 800;
}

.entry-button {
  flex: 0 0 auto;
  width: 176rpx;
  height: 68rpx;
  margin: 0;
  padding: 0 20rpx;
  box-sizing: border-box;
  border-radius: 34rpx;
  background: linear-gradient(135deg, #188be4, #1fb9a5);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 68rpx;
  white-space: nowrap;
}

.score-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 22rpx;
  padding: 30rpx;
}

.score-label {
  color: #7a8799;
  font-size: 24rpx;
}

.score-title {
  margin-top: 8rpx;
  font-size: 38rpx;
  font-weight: 800;
}

.score-left {
  flex: 1;
  min-width: 0;
  padding-right: 24rpx;
}

.score-ring {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 142rpx;
  height: 142rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #188be4, #1fb9a5);
  color: #fff;
}

.score-ring text:first-child {
  font-size: 42rpx;
  font-weight: 800;
}

.score-ring text:last-child {
  font-size: 22rpx;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  margin-top: 22rpx;
}

.metric-card {
  padding: 26rpx;
}

.metric-card text {
  display: block;
}

.metric-card text:first-child {
  font-size: 36rpx;
  font-weight: 800;
}

.metric-card text:last-child {
  margin-top: 8rpx;
  color: #7a8799;
  font-size: 24rpx;
}

.down {
  color: #12a66a;
}

.up {
  color: #ff6470;
}

.chart-card,
.habit-card,
.insight-card {
  margin-top: 22rpx;
  padding: 28rpx;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
}

.granularity-tabs {
  display: flex;
  flex-shrink: 0;
  padding: 6rpx;
  border-radius: 16rpx;
  background: #edf3f8;
}

.granularity-tab {
  min-width: 72rpx;
  height: 48rpx;
  padding: 0 12rpx;
  border-radius: 12rpx;
  color: #627086;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 48rpx;
  text-align: center;
}

.granularity-tab.active {
  background: #fff;
  color: #188be4;
  box-shadow: 0 6rpx 16rpx rgba(31, 54, 86, 0.08);
}

.chart-box {
  height: 430rpx;
  margin-top: 18rpx;
}

.chart-box ec-canvas {
  width: 100%;
  height: 100%;
}

.chart-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 240rpx;
  color: #7a8799;
  font-size: 26rpx;
}

.weekday-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 24rpx;
}

.weekday-name {
  width: 70rpx;
  color: #596579;
  font-size: 24rpx;
}

.weekday-track {
  flex: 1;
  height: 16rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #ecf1f6;
}

.weekday-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #188be4, #1fb9a5);
}

.weekday-count {
  width: 42rpx;
  text-align: right;
  color: #172033;
  font-size: 24rpx;
  font-weight: 700;
}

.insight-line {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: #f6f8fb;
  color: #344157;
  font-size: 26rpx;
  line-height: 1.55;
}

.style-mask {
  position: fixed;
  z-index: 1000;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  background: rgba(18, 28, 42, 0.48);
}

.style-sheet {
  width: 100%;
  padding: 18rpx 28rpx 36rpx;
  border-radius: 30rpx 30rpx 0 0;
  background: #fff;
  box-sizing: border-box;
  box-shadow: 0 -16rpx 44rpx rgba(24, 54, 87, 0.18);
}

.style-sheet-handle {
  width: 72rpx;
  height: 8rpx;
  margin: 0 auto 22rpx;
  border-radius: 999rpx;
  background: #d8e1ea;
}

.style-sheet-title {
  color: #172033;
  font-size: 36rpx;
  font-weight: 800;
}

.style-sheet-subtitle {
  margin-top: 8rpx;
  color: #7a8799;
  font-size: 24rpx;
}

.style-option {
  min-height: 106rpx;
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  background: #f6f8fb;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.style-option-title {
  color: #172033;
  font-size: 30rpx;
  font-weight: 800;
}

.style-option-desc {
  margin-top: 8rpx;
  color: #7a8799;
  font-size: 24rpx;
  line-height: 1.45;
}

.style-option-mark {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #edf6ff;
  color: #188be4;
  font-size: 22rpx;
  font-weight: 800;
}
