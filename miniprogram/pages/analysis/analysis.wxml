<view class="page">
  <view class="scope-tabs">
    <view class="scope-tab {{scope === 'month' ? 'active' : ''}}" data-scope="month" bindtap="changeScope">本月</view>
    <view class="scope-tab {{scope === 'year' ? 'active' : ''}}" data-scope="year" bindtap="changeScope">今年</view>
    <view class="scope-tab {{scope === 'all' ? 'active' : ''}}" data-scope="all" bindtap="changeScope">全部</view>
  </view>

  <view class="month-panel">
    <button class="month-arrow {{scope === 'all' ? 'disabled' : ''}}" bindtap="prevMonth">‹</button>
    <view class="month-center">
      <view class="month-title">{{periodTitle}}</view>
      <view class="month-subtitle">{{periodSubtitle}}</view>
    </view>
    <button class="month-arrow {{scope === 'all' ? 'disabled' : ''}}" bindtap="nextMonth">›</button>
  </view>

  <view class="report-entry">
    <view>
      <view class="entry-title">{{reportTitle}}</view>
      <view class="entry-subtitle">{{reportSubtitle}}</view>
    </view>
    <button class="entry-button" bindtap="watchReportAd">{{reportButtonText}}</button>
  </view>

  <view class="score-card">
    <view class="score-left">
      <view class="score-label">记录状态</view>
      <view class="score-title">{{scoreTitle}}</view>
      <view class="score-desc">{{scoreDesc}}</view>
    </view>
    <view class="score-ring">
      <text>{{habitScore}}</text>
      <text>分</text>
    </view>
  </view>

  <view class="metric-grid">
    <view class="metric-card">
      <text>{{summary.days}}</text>
      <text>打卡天数</text>
    </view>
    <view class="metric-card">
      <text class="{{summary.changeClass}}">{{summary.changeText}}</text>
      <text>体重变化</text>
    </view>
    <view class="metric-card">
      <text>{{summary.avgWeight}}</text>
      <text>平均体重</text>
    </view>
    <view class="metric-card">
      <text>{{summary.latestBmi}}</text>
      <text>最新 BMI</text>
    </view>
  </view>

  <view class="chart-card">
    <view class="section-head">
      <view>
        <view class="section-title">趋势细节</view>
        <view class="section-subtitle">{{trendSubtitle}}</view>
      </view>
      <view class="granularity-tabs" wx:if="{{scope !== 'month'}}">
        <view class="granularity-tab {{chartGranularity === 'day' ? 'active' : ''}}" data-granularity="day" bindtap="changeGranularity">按天</view>
        <view class="granularity-tab {{chartGranularity === 'month' ? 'active' : ''}}" data-granularity="month" bindtap="changeGranularity">按月</view>
      </view>
    </view>
    <view class="chart-empty" wx:if="{{!hasChartData}}">记录两次以上会更有参考价值</view>
    <view class="chart-box" wx:elif="{{!showStyleSheet}}">
      <ec-canvas id="analysis-chart" canvas-id="analysis-chart" ec="{{ec}}"></ec-canvas>
    </view>
  </view>

  <view class="habit-card">
    <view class="section-title">打卡习惯</view>
    <view class="weekday-row" wx:for="{{weekdayStats}}" wx:key="name">
      <view class="weekday-name">{{item.name}}</view>
      <view class="weekday-track">
        <view class="weekday-fill" style="width: {{item.percent}}%"></view>
      </view>
      <view class="weekday-count">{{item.count}}</view>
    </view>
  </view>

  <view class="insight-card">
    <view class="section-title">建议</view>
    <view class="insight-line" wx:for="{{insights}}" wx:key="*this">{{item}}</view>
  </view>

  <view class="style-mask" wx:if="{{showStyleSheet}}" bindtap="closeStyleSheet">
    <view class="style-sheet" catchtap="noop">
      <view class="style-sheet-handle"></view>
      <view class="style-sheet-title">选择报告风格</view>
      <view class="style-sheet-subtitle">选好风格后观看广告，生成对应 AI 报告</view>
      <view class="style-option" data-style="professional" bindtap="selectReportStyle">
        <view>
          <view class="style-option-title">专业</view>
          <view class="style-option-desc">克制清晰，偏数据分析</view>
        </view>
        <view class="style-option-mark" wx:if="{{reportStyle === 'professional'}}">已选</view>
      </view>
      <view class="style-option" data-style="encourage" bindtap="selectReportStyle">
        <view>
          <view class="style-option-title">鼓励</view>
          <view class="style-option-desc">温暖积极，适合需要一点动力的时候</view>
        </view>
        <view class="style-option-mark" wx:if="{{reportStyle === 'encourage'}}">已选</view>
      </view>
      <view class="style-option" data-style="roast" bindtap="selectReportStyle">
        <view>
          <view class="style-option-title">毒嘴</view>
          <view class="style-option-desc">善意吐槽，嘴上不饶人但不制造焦虑</view>
        </view>
        <view class="style-option-mark" wx:if="{{reportStyle === 'roast'}}">已选</view>
      </view>
    </view>
  </view>
</view>
