<view class="page">
  <view class="calendar-section">
    <weight-calendar
      year-month="{{currentMonth}}"
      selected-date="{{selectedDate}}"
      records-map="{{recordsMap}}"
      bind:prev="prevMonth"
      bind:next="nextMonth"
      bind:select="onCalendarSelect"
      bind:records="goRecords"
    />
  </view>

  <view class="middle-showcase">
    <view class="middle-glow one"></view>
    <view class="middle-glow two"></view>
    <view class="overview-card">
      <view class="card-sparkle star-a">✦</view>
      <view class="card-sparkle star-b">✦</view>
      <view class="today-card-head">
        <view class="today-title-wrap">
          <image class="today-title-icon" src="../../瘦身打卡助手_透明小图标PNG/11_累计打卡_日历图标.png" mode="aspectFit"></image>
          <view class="today-title">今日体重</view>
        </view>
        <button class="checkin-btn" bindtap="openCheckin">
          <text>今日打卡</text>
        </button>
      </view>

      <view class="today-metrics">
        <view class="today-weight" bindtap="openCheckin">
          <view class="today-label">今日体重</view>
          <view class="weight-value">
            <text>{{displayWeight || '--'}}</text>
            <text class="weight-unit">斤</text>
          </view>
        </view>

        <view class="today-progress">
          <view class="today-label">{{monthTrendLabel}}</view>
          <view class="loss-value {{monthChangeClass}}">
            <text>{{monthLossValue}}</text>
            <text class="loss-unit">斤</text>
          </view>
        </view>

        <view class="today-target" bindtap="goUserInfoTarget">
          <view class="today-label target-label">
            <text>本月目标</text>
            <van-icon name="edit" class="target-edit-icon" />
          </view>
          <view class="target-value">
            <text>{{aimWeightText}}</text>
            <text class="target-unit">斤</text>
          </view>
        </view>
      </view>

      <view class="today-progress-footer">
        <view class="today-chip-row">
          <view class="bmi-pill {{bmiClass}}" catchtap="showBmiInfo">
            <text>BMI {{bmiValue || '--'}}</text>
            <text class="bmi-divider">·</text>
            <text class="bmi-status-inline">{{bmiLabel || '待完善'}}</text>
            <van-icon name="arrow" class="bmi-arrow" />
          </view>
        </view>
        <view class="progress-inline">
          <view class="progress-track">
            <view class="progress-fill" style="width: {{targetProgress}}%"></view>
          </view>
          <view class="progress-meta">
            <text>目标进度 <text class="progress-percent {{targetProgressDisplay < 0 ? 'negative' : ''}}">{{targetProgressDisplay}}%</text></text>
            <text>还需 {{targetDistanceValue}}斤</text>
          </view>
        </view>
      </view>
    </view>

    <view class="quick-actions">
      <view class="quick-action ai" bindtap="goAnalysis">
        <view class="quick-icon-bubble">
          <image class="quick-icon" src="../../瘦身打卡助手_透明小图标PNG/08_AI分析_机器人图标.png" mode="aspectFit"></image>
        </view>
        <view class="quick-copy">
          <view class="quick-title">AI分析</view>
          <view class="quick-subtitle">智能解读数据</view>
        </view>
        <van-icon name="arrow" class="quick-arrow" />
      </view>
      <view class="quick-action group" bindtap="openJoinGroupDialog">
        <view class="quick-icon-bubble">
          <image class="quick-icon" src="../../瘦身打卡助手_透明小图标PNG/09_加群交流_群聊图标.png" mode="aspectFit"></image>
        </view>
        <view class="quick-copy">
          <view class="quick-title">加群交流</view>
          <view class="quick-subtitle">一起打卡</view>
        </view>
        <van-icon name="arrow" class="quick-arrow" />
      </view>
      <view class="quick-action share" bindtap="openSharePanel">
        <view class="quick-icon-bubble">
          <image class="quick-icon" src="../../瘦身打卡助手_透明小图标PNG/10_分享成果_分享图标.png" mode="aspectFit"></image>
        </view>
        <view class="quick-copy">
          <view class="quick-title">分享成果</view>
          <view class="quick-subtitle">记录变化</view>
        </view>
        <van-icon name="arrow" class="quick-arrow" />
      </view>
    </view>
  </view>

  <view class="share-nudge" wx:if="{{showShareNudge}}">
    <view class="share-nudge-copy">
      <view class="share-nudge-title">今天已打卡</view>
      <view class="share-nudge-desc">要不要分享一下成果？</view>
    </view>
    <view class="share-nudge-actions">
      <button class="nudge-primary" bindtap="openSharePanel">分享成果</button>
      <button class="nudge-secondary" bindtap="dismissShareNudge">暂不</button>
    </view>
  </view>

  <view class="trend-card">
    <view class="section-head">
      <view class="trend-title-wrap">
        <image class="trend-title-icon" src="../../瘦身打卡助手_透明小图标PNG/13_本月变化_趋势图标.png" mode="aspectFit"></image>
        <view class="card-title">本月趋势</view>
      </view>
      <view class="trend-legend">
        <view class="legend-item">
          <view class="legend-line weight"></view>
          <text class="legend-text">体重(斤)</text>
        </view>
        <view class="legend-item">
          <view class="legend-line target"></view>
          <text class="legend-text">目标(斤)</text>
        </view>
      </view>
    </view>
    <view class="chart-empty" wx:if="{{!hasChartData}}">
      记录两次体重后，将生成趋势图
    </view>
    <view class="chart-box" wx:else>
      <ec-canvas wx:if="{{!showCheckinDialog && !showSharePanel && !visibleJoinGroup && !showCheckinSuccessDialog && !showBmiDialog && !showOnboarding}}" id="trend-chart" canvas-id="trend-chart" ec="{{ec}}"></ec-canvas>
      <view wx:else class="chart-hidden-placeholder"></view>
    </view>
  </view>

  <view class="onboarding-mask" wx:if="{{showOnboarding}}">
    <view class="onboarding-card">
      <view class="onboarding-accent"></view>
      <view class="onboarding-badge">首次记录</view>
      <view class="onboarding-title">开始你的体重打卡</view>
      <view class="onboarding-desc">填好基础信息，明天按时回来记录一次</view>
      <view class="onboarding-form">
        <view class="form-row onboarding-field">
          <view class="field-copy">
            <text class="field-label">身高</text>
            <text class="field-hint">用于计算 BMI</text>
          </view>
          <view class="field-input">
            <input type="digit" value="{{newUserHeight}}" placeholder="例如 170" bindinput="onNewHeightInput" />
            <text>cm</text>
          </view>
        </view>
        <view class="form-row onboarding-field">
          <view class="field-copy">
            <text class="field-label">当前体重</text>
            <text class="field-hint">今天的第一条记录</text>
          </view>
          <view class="field-input">
            <input type="digit" value="{{newUserWeight}}" placeholder="例如 150" bindinput="onNewWeightInput" />
            <text>斤</text>
          </view>
        </view>
        <view class="form-row onboarding-field">
          <view class="field-copy">
            <text class="field-label">目标体重</text>
            <text class="field-hint">设定一个阶段目标</text>
          </view>
          <view class="field-input">
            <input type="digit" value="{{newUserTarget}}" placeholder="例如 130" bindinput="onNewTargetInput" />
            <text>斤</text>
          </view>
        </view>
      </view>
      <view class="onboarding-reminder">
        <view class="reminder-card">
          <view class="reminder-main">
            <view class="reminder-title-row">
              <text class="reminder-dot"></text>
              <text>明天提醒我打卡</text>
            </view>
            <view class="reminder-desc">建议新用户先把提醒打开</view>
          </view>
          <van-checkbox custom-class="reminder-checkbox" value="{{ subscribeChecked }}" bind:change="onSubscribeCheckboxChange" />
        </view>
        <view wx:if="{{ subscribeChecked }}" class="reminder-time-field onboarding-time" bindtap="showReminderTimePicker">
          <view>
            <text class="reminder-time-label">提醒时间</text>
            <text class="reminder-time-tip">明天 {{ reminderTime }}</text>
          </view>
          <view class="reminder-time-right">
            <text class="reminder-time-value">{{ reminderTime }}</text>
            <van-icon name="arrow" class="reminder-time-arrow" />
          </view>
        </view>
      </view>
      <button class="primary-action" bindtap="submitOnboarding">开始记录</button>
      <view class="helper-text">完成后会保存今天的第一条体重记录</view>
    </view>
  </view>

  <view class="checkin-mask" wx:if="{{showCheckinDialog}}">
    <view class="checkin-dialog-card">
      <view class="onboarding-accent"></view>
      <view class="checkin-dialog-head">
        <view>
          <view class="checkin-dialog-title">{{hasSelectedRecord ? '修改体重记录' : '今日打卡'}}</view>
          <view class="checkin-dialog-subtitle">{{selectedDate}}</view>
        </view>
        <view class="checkin-dialog-badge">{{hasSelectedRecord ? '编辑' : '记录'}}</view>
      </view>

      <view class="checkin-input-grid">
        <view class="checkin-input-card">
          <view class="checkin-input-label">体重</view>
          <view class="checkin-input-row">
            <input type="digit" value="{{checkinWeight}}" bindinput="onCheckinWeightInput" />
            <text>斤</text>
          </view>
        </view>
        <view class="checkin-input-card kg">
          <view class="checkin-input-label">千克</view>
          <view class="checkin-input-row">
            <input type="digit" value="{{checkinWeightKg}}" bindinput="onCheckinWeightKgChange" />
            <text>kg</text>
          </view>
        </view>
      </view>

      <view class="checkin-reminder">
        <view class="reminder-card checkin-reminder-card">
          <view class="reminder-main">
            <view class="reminder-title-row">
              <text class="reminder-dot"></text>
              <text>明天提醒我打卡</text>
            </view>
            <view class="reminder-desc">开启后会按你选的时间提醒</view>
          </view>
          <van-checkbox custom-class="reminder-checkbox" value="{{ subscribeChecked }}" bind:change="onSubscribeCheckboxChange" />
        </view>
        <view wx:if="{{ subscribeChecked }}" class="reminder-time-field onboarding-time checkin-time" bindtap="showReminderTimePicker">
          <view>
            <text class="reminder-time-label">提醒时间</text>
            <text class="reminder-time-tip">明天 {{ reminderTime }}</text>
          </view>
          <view class="reminder-time-right">
            <text class="reminder-time-value">{{ reminderTime }}</text>
            <van-icon name="arrow" class="reminder-time-arrow" />
          </view>
        </view>
      </view>

      <view class="checkin-actions">
        <button class="secondary-checkin-action" bindtap="closeCheckin">取消</button>
        <button class="primary-checkin-action" bindtap="submitCheckin">{{hasSelectedRecord ? '保存修改' : '完成打卡'}}</button>
      </view>
    </view>
  </view>

  <view class="success-mask" wx:if="{{showCheckinSuccessDialog}}" bindtap="closeCheckinSuccess">
    <view class="success-dialog-card" catchtap="noop">
      <image class="success-hero-icon" src="../../images/checkin-dialog/success-hero.png" mode="aspectFit"></image>
      <view class="success-close" bindtap="closeCheckinSuccess">×</view>
      <view class="success-title">打卡成功</view>
      <view class="success-subtitle">今天也认真记录啦</view>

      <view class="success-weight-card">
        <view class="success-weight-value">
          <text>{{checkinSuccess.weightText || '--'}}</text>
          <text class="success-weight-unit">斤</text>
        </view>
        <view class="success-weight-label">今日体重</view>
        <view class="success-bmi {{checkinSuccess.bmiClass}}">{{checkinSuccess.bmiText}}</view>
      </view>

      <view class="success-stats">
        <view class="success-stat-card">
          <image class="success-stat-icon" src="../../images/checkin-dialog/calendar.png" mode="aspectFit"></image>
          <view class="success-stat-label">本月已打卡</view>
          <view class="success-stat-text">{{checkinSuccess.monthDaysValue || checkinSuccess.monthDaysText}}</view>
        </view>
        <view class="success-stat-card">
          <image class="success-stat-icon" src="../../images/checkin-dialog/trend-down.png" mode="aspectFit"></image>
          <view class="success-stat-label">本月变化</view>
          <view class="success-stat-text">{{checkinSuccess.monthChangeValue || checkinSuccess.monthChangeText}}</view>
        </view>
        <view class="success-stat-card">
          <image class="success-stat-icon" src="../../images/checkin-dialog/target.png" mode="aspectFit"></image>
          <view class="success-stat-label">距目标</view>
          <view class="success-stat-text">{{checkinSuccess.targetValue || checkinSuccess.targetText}}</view>
        </view>
      </view>

      <view class="success-encourage">
        <text>继续保持，明天再来打卡</text>
      </view>
      <view class="success-actions">
        <button class="success-primary" bindtap="goSuccessAnalysis">查看AI分析</button>
        <button class="success-secondary" open-type="share" data-share-type="checkin">
          <image class="success-share-icon" src="../../images/checkin-dialog/share.png" mode="aspectFit"></image>
          <text>分享给好友</text>
        </button>
      </view>
      <view class="success-footer-close" bindtap="closeCheckinSuccess">关闭</view>
    </view>
  </view>

  <van-popup show="{{visibleReminderTimePicker}}" position="bottom" bind:close="onReminderTimeCancel" z-index="100001">
    <van-datetime-picker
      type="time"
      value="{{reminderTime}}"
      bind:confirm="onReminderTimeConfirm"
      bind:cancel="onReminderTimeCancel"
    />
  </van-popup>

  <view class="onboarding-mask" wx:if="{{showBmiDialog}}">
    <view class="bmi-dialog-card">
      <view class="bmi-dialog-title">BMI 中国标准</view>
      <view class="bmi-current" wx:if="{{bmiValue}}">
        你的 BMI
        <text class="{{bmiClass}}">{{bmiValue}}</text>
        <text>{{bmiLabel}}</text>
      </view>
      <view class="bmi-current" wx:else>完善身高和体重后可查看当前位置</view>

      <view class="bmi-range-bar">
        <view class="bmi-range-container">
          <view class="bmi-range-item thin">
            <text>偏瘦</text>
            <text>≤18.4</text>
          </view>
          <view class="bmi-range-item normal">
            <text>正常</text>
            <text>18.5~23.9</text>
          </view>
          <view class="bmi-range-item overweight">
            <text>超重</text>
            <text>24.0~27.9</text>
          </view>
          <view class="bmi-range-item obese">
            <text>肥胖</text>
            <text>≥28.0</text>
          </view>
        </view>
        <view class="bmi-marker" wx:if="{{bmiValue}}" style="left: {{bmiMarkerPosition}}%">
          <view class="bmi-marker-triangle"></view>
          <view class="bmi-marker-label">当前</view>
        </view>
      </view>

      <view class="bmi-text">
        BMI = 体重(kg) / 身高(m)²，只是健康参考指标之一，建议结合腰围、体脂和身体状态一起看。
      </view>
      <button class="primary-action" bindtap="closeBmiInfo">知道了</button>
    </view>
  </view>

  <view class="share-mask" wx:if="{{showSharePanel}}" bindtap="closeSharePanel">
    <view class="share-sheet" catchtap="noop">
      <view class="share-sheet-handle"></view>
      <view class="share-sheet-head">
        <view>
          <view class="share-sheet-title">分享成果</view>
          <view class="share-sheet-desc">{{sharePreviewText}}</view>
        </view>
        <view class="share-sheet-close" bindtap="closeSharePanel">×</view>
      </view>

      <view class="share-option-list">
        <button class="share-option" open-type="share" bindtap="closeSharePanel">
          <view class="share-option-icon friend">
            <van-icon name="friends-o" />
          </view>
          <view class="share-option-copy">
            <view class="share-option-title">分享给好友</view>
            <view class="share-option-desc">发给朋友或群聊，一起打卡</view>
          </view>
          <van-icon name="arrow" class="share-option-arrow" />
        </button>

        <view class="share-option" bindtap="guideShareTimeline">
          <view class="share-option-icon timeline">
            <van-icon name="photo-o" />
          </view>
          <view class="share-option-copy">
            <view class="share-option-title">分享到朋友圈</view>
            <view class="share-option-desc">使用右上角菜单发布卡片</view>
          </view>
          <van-icon name="arrow" class="share-option-arrow" />
        </view>

        <view class="share-sheet-note">当前分享的是小程序卡片，标题会按本月变化自动生成。</view>
      </view>
    </view>
  </view>

  <van-dialog cancelButtonText="取消" confirmButtonText="保存" bind:close="closeJoinGroup" closeOnClickOverlay="{{true}}" use-slot show="{{visibleJoinGroup}}" showCancelButton="{{true}}" zIndex="1000001">
    <view class="join-group-dialog">
      <image class="join-group-image" src="{{htmlImage}}" show-menu-by-longpress mode="widthFix"></image>
    </view>
  </van-dialog>
</view>
