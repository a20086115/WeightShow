/* 蓝色氛围版首页中段 */
.middle-showcase {
  position: relative;
  margin: 12rpx -22rpx 0;
  padding: 22rpx 22rpx 24rpx;
  background:
    radial-gradient(circle at 14% 24%, rgba(255, 255, 255, 0.72) 0, rgba(255, 255, 255, 0) 24%),
    radial-gradient(circle at 88% 12%, rgba(255, 255, 255, 0.55) 0, rgba(255, 255, 255, 0) 22%),
    linear-gradient(135deg, #7dc9ff 0%, #bde9ff 45%, #eefbff 100%);
  overflow: hidden;
}

.middle-showcase::before,
.middle-showcase::after {
  content: "";
  position: absolute;
  border-radius: 999rpx;
  pointer-events: none;
}

.middle-showcase::before {
  width: 520rpx;
  height: 180rpx;
  left: -120rpx;
  top: 120rpx;
  background: rgba(255, 255, 255, 0.28);
  transform: rotate(-18deg);
}

.middle-showcase::after {
  width: 460rpx;
  height: 150rpx;
  right: -120rpx;
  bottom: 70rpx;
  background: rgba(255, 255, 255, 0.22);
  transform: rotate(-14deg);
}

.middle-glow {
  position: absolute;
  z-index: 0;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.36);
  filter: blur(2rpx);
}

.middle-glow.one {
  width: 180rpx;
  height: 180rpx;
  left: -44rpx;
  top: 18rpx;
}

.middle-glow.two {
  width: 220rpx;
  height: 220rpx;
  right: -64rpx;
  top: -38rpx;
}

.middle-showcase .overview-card {
  position: relative;
  z-index: 1;
  margin-top: 0;
  padding: 34rpx 34rpx 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.82);
