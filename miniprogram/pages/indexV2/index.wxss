.page {
  min-height: 100vh;
  padding: 18rpx 22rpx 40rpx;
  background: #f6f8fb;
  box-sizing: border-box;
}

.calendar-section {
  margin-top: 8rpx;
}

.overview-card,
.quick-actions,
.stats-card,
.trend-card {
  margin-top: 18rpx;
  padding: 20rpx;
  background: #ffffff;
  border: 1rpx solid #eef3f8;
  border-radius: 18rpx;
  box-shadow: 0 12rpx 26rpx rgba(32, 58, 84, 0.08);
  box-sizing: border-box;
}

.overview-card {
  margin-top: 8rpx;
  padding: 18rpx 18rpx 20rpx;
}

.overview-head,
.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-title {
  color: #21304a;
  font-size: 30rpx;
  font-weight: 700;
}

.card-subtitle {
  margin-top: 6rpx;
  color: #75849a;
  font-size: 23rpx;
}

.checkin-btn {
  height: 58rpx;
  margin: 0;
  padding: 0 20rpx;
  border: 0;
  border-radius: 29rpx;
  background: #167cff;
  color: #ffffff;
  box-shadow: 0 10rpx 18rpx rgba(22, 124, 255, 0.22);
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  line-height: 58rpx;
}

.checkin-btn::after,
.share-entry-btn::after,
.share-option::after,
.nudge-primary::after,
.nudge-secondary::after,
.primary-action::after,
.secondary-action::after,
.primary-checkin-action::after,
.secondary-checkin-action::after,
.success-primary::after,
.success-secondary::after,
.quick-action::after {
  border: 0;
}

.checkin-plus {
  font-size: 30rpx;
  font-weight: 700;
}

.overview-actions {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.share-entry-btn {
  height: 62rpx;
  margin: 0;
  padding: 0 18rpx;
  border: 1rpx solid #cfe7fb;
  border-radius: 31rpx;
  background: #f3f9ff;
  color: #188be4;
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 62rpx;
}

.share-entry-icon {
  font-size: 28rpx;
}

.overview-main {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.metric-card {
  position: relative;
  min-width: 0;
  min-height: 184rpx;
  padding: 22rpx 20rpx 20rpx;
  border-radius: 18rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.weight-main {
  background: linear-gradient(135deg, #effdf7 0%, #f5fbff 58%, #ffffff 100%);
  border: 1rpx solid #ddf4ec;
}

.bmi-panel {
  background: linear-gradient(135deg, #faf2ff 0%, #f7f2ff 60%, #ffffff 100%);
  border: 1rpx solid #ece0ff;
}

.metric-card-top {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  color: #24415c;
  font-size: 25rpx;
  font-weight: 700;
}

.metric-icon {
  flex-shrink: 0;
  width: 34rpx;
  height: 34rpx;
  margin-right: 10rpx;
}

.weight-value {
  position: relative;
  z-index: 2;
  margin-top: 10rpx;
  color: #102b4c;
  font-weight: 800;
}

.weight-value text:first-child {
  font-size: 70rpx;
  line-height: 78rpx;
}

.weight-unit {
  margin-left: 6rpx;
  color: #1f2d3d;
  font-size: 26rpx;
  font-weight: 700;
}

.change-chip,
.bmi-tag {
  position: relative;
  z-index: 2;
  display: inline-flex;
  align-items: center;
  height: 40rpx;
  margin-top: 8rpx;
  padding: 0 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.change-down,
.month-down {
  color: #18ad73;
}

.change-up,
.month-up {
  color: #ff4f68;
}

.change-chip.change-down {
  background: #dff8eb;
}

.change-chip.change-up {
  background: #fff0f2;
}

.bmi-value {
  position: relative;
  z-index: 2;
  margin-top: 10rpx;
  color: #6a35ff;
  font-size: 66rpx;
  line-height: 76rpx;
  font-weight: 800;
}

.bmi-tag {
  background: #fff0f2;
  color: #ff4f68;
}

.bmi-tag.normal {
  background: #e9f8ef;
  color: #18ad73;
}

.bmi-label {
  padding-right: 2rpx;
}

.info-dot {
  margin-left: auto;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.82);
  color: #7d4cff;
  font-size: 20rpx;
  font-weight: 800;
}

.card-curve {
  display: none;
}

.curve-line {
  display: none;
}

.curve-dot {
  display: none;
}

.weight-curve {
  color: #26ccb5;
}

.bmi-curve {
  color: #9b75ff;
}

.target-block {
  margin-top: 18rpx;
}

.target-line {
  color: #51627a;
  font-size: 23rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.progress-track {
  height: 12rpx;
  margin-top: 12rpx;
  border-radius: 999rpx;
  background: #e8edf5;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #167cff;
}

.quick-actions {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  padding: 14rpx;
}

.quick-action {
  min-width: 0;
  min-height: 124rpx;
  padding: 16rpx 10rpx 14rpx;
  border-radius: 18rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.quick-action.ai {
  background: #f2f8ff;
}

.quick-action.group {
  background: #f1fbf1;
}

.quick-action.share {
  background: #fff6ed;
}

.quick-icon {
  flex-shrink: 0;
  width: 48rpx;
  height: 48rpx;
  margin-right: 0;
  margin-bottom: 10rpx;
}

.quick-copy {
  min-width: 0;
  width: 100%;
}

.quick-title {
  color: #22314a;
  font-size: 24rpx;
  font-weight: 800;
  white-space: nowrap;
}

.quick-subtitle {
  margin-top: 6rpx;
  color: #718095;
  font-size: 20rpx;
  line-height: 1.2;
  white-space: nowrap;
}

.quick-arrow {
  display: none;
}

.group .quick-arrow {
  color: #1ba85a;
}

.share .quick-arrow {
  color: #ff8a2a;
}

.stat-row {
  min-height: 124rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
}

.stat-item {
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-right: 1rpx solid #edf1f6;
}

.stat-item:last-child {
  border-right: 0;
}

.stat-icon {
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  margin-right: 0;
  margin-bottom: 10rpx;
}

.stat-copy {
  min-width: 0;
  text-align: center;
}

.stat-value {
  color: #21304a;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.15;
  white-space: nowrap;
}

.stat-label {
  margin-top: 4rpx;
  color: #718095;
  font-size: 21rpx;
  white-space: nowrap;
}

.share-nudge {
  min-height: 112rpx;
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
  border-radius: 22rpx;
  background: #f3faf8;
  border: 1rpx solid #dff2ed;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.share-nudge-copy {
  min-width: 0;
}

.share-nudge-title {
  color: #1f2d3d;
  font-size: 27rpx;
  font-weight: 800;
}

.share-nudge-desc {
  margin-top: 6rpx;
  color: #6d8a85;
  font-size: 23rpx;
}

.share-nudge-actions {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.nudge-primary,
.nudge-secondary {
  height: 58rpx;
  margin: 0;
  padding: 0 18rpx;
  border: 0;
  border-radius: 29rpx;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 58rpx;
}

.nudge-primary {
  background: #167cff;
  color: #ffffff;
  box-shadow: 0 8rpx 16rpx rgba(22, 124, 255, 0.18);
}

.nudge-secondary {
  background: #ffffff;
  color: #7d8790;
}

.chart-box {
  height: 420rpx;
  margin-top: 12rpx;
}

.chart-box ec-canvas {
  width: 100%;
  height: 100%;
}

.chart-hidden-placeholder {
  width: 100%;
  height: 100%;
}

.chart-empty {
  height: 260rpx;
  color: #9aa6b2;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.join-group-dialog {
  max-height: 850rpx;
  overflow: scroll;
}

.join-group-image {
  width: 100%;
  display: block;
}

.onboarding-mask {
  position: fixed;
  z-index: 9999;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  padding: 40rpx 44rpx;
  background: rgba(20, 32, 45, 0.46);
  display: flex;
  align-items: center;
  justify-content: center;
}

.onboarding-card {
  position: relative;
  width: 100%;
  max-height: 92vh;
  padding: 42rpx 34rpx 34rpx;
  border-radius: 30rpx;
  background: #ffffff;
  box-sizing: border-box;
  overflow: hidden;
  box-shadow: 0 28rpx 60rpx rgba(24, 54, 87, 0.22);
}

.onboarding-accent {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 8rpx;
  background: linear-gradient(90deg, #188be4 0%, #20b7a7 58%, #ffb45f 100%);
}

.onboarding-badge {
  width: 128rpx;
  margin: 0 auto 16rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #eef7ff;
  color: #188be4;
  font-size: 22rpx;
  font-weight: 700;
}

.checkin-card {
  transform: translateY(-80rpx);
}

.checkin-mask {
  position: fixed;
  z-index: 100000;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  padding: 40rpx 44rpx;
  background: rgba(20, 32, 45, 0.48);
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkin-dialog-card {
  position: relative;
  width: 100%;
  max-height: 90vh;
  padding: 38rpx 32rpx 32rpx;
  border-radius: 30rpx;
  background: #ffffff;
  box-sizing: border-box;
  overflow: hidden;
  box-shadow: 0 28rpx 60rpx rgba(24, 54, 87, 0.24);
}

.checkin-dialog-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.checkin-dialog-title {
  color: #1f2d3d;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.2;
  letter-spacing: 0;
}

.checkin-dialog-subtitle {
  margin-top: 10rpx;
  color: #8a97a3;
  font-size: 25rpx;
}

.checkin-dialog-badge {
  flex-shrink: 0;
  margin-top: 2rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #eef7ff;
  color: #188be4;
  font-size: 22rpx;
  font-weight: 700;
}

.checkin-input-grid {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 30rpx;
}

.checkin-input-card {
  min-width: 0;
  min-height: 112rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: #f3f9ff;
  border: 1rpx solid #e4f0fb;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.checkin-input-card.kg {
  background: #f8fbfe;
  border-color: #edf2f7;
}

.checkin-input-label {
  color: #7d8790;
  font-size: 24rpx;
  font-weight: 700;
}

.checkin-input-row {
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
  min-width: 0;
  flex: 1;
}

.checkin-input-row input {
  width: 280rpx;
  min-width: 0;
  color: #1f2d3d;
  font-size: 40rpx;
  font-weight: 800;
  text-align: right;
}

.checkin-input-row text {
  flex-shrink: 0;
  margin-left: 8rpx;
  color: #657381;
  font-size: 24rpx;
  font-weight: 700;
}

.checkin-reminder {
  margin-top: 22rpx;
}

.checkin-reminder-card {
  min-height: 96rpx;
  padding: 18rpx 20rpx;
}

.checkin-time {
  margin-top: 14rpx;
}

.checkin-actions {
  display: grid;
  grid-template-columns: 190rpx minmax(0, 1fr);
  gap: 18rpx;
  margin-top: 30rpx;
}

.secondary-checkin-action,
.primary-checkin-action {
  height: 82rpx;
  margin: 0;
  border: 0;
  border-radius: 41rpx;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 82rpx;
}

.secondary-checkin-action {
  background: #f2f6fa;
  color: #657381;
}

.primary-checkin-action {
  background: #188be4;
  color: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(24, 139, 228, 0.24);
}

.success-mask {
  position: fixed;
  z-index: 100003;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  padding: 92rpx 44rpx 40rpx;
  background: rgba(7, 18, 31, 0.66);
  display: flex;
  align-items: center;
  justify-content: center;
}

.success-dialog-card {
  position: relative;
  width: 100%;
  max-height: 88vh;
  padding: 112rpx 42rpx 30rpx;
  border: 1rpx solid rgba(219, 236, 255, 0.95);
  border-radius: 34rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
  box-sizing: border-box;
  overflow: visible;
  box-shadow: 0 34rpx 86rpx rgba(3, 18, 38, 0.3);
}

.success-hero-icon {
  position: absolute;
  top: -120rpx;
  left: 50%;
  z-index: 2;
  width: 270rpx;
  height: 214rpx;
  transform: translateX(-50%);
  display: block;
}

.success-close {
  position: absolute;
  top: 32rpx;
  right: 30rpx;
  width: 54rpx;
  height: 54rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 50%;
  background: #f7f9fb;
  color: #a0a8b4;
  font-size: 36rpx;
  line-height: 48rpx;
  text-align: center;
  box-sizing: border-box;
}

.success-title {
  color: #101b2f;
  font-size: 56rpx;
  font-weight: 900;
  line-height: 1.2;
  text-align: center;
  letter-spacing: 0;
}

.success-subtitle {
  margin-top: 10rpx;
  color: #738196;
  font-size: 28rpx;
  text-align: center;
}

.success-weight-card {
  position: relative;
  margin-top: 30rpx;
  padding: 34rpx 26rpx 32rpx;
  border: 1rpx solid #c7ddff;
  border-radius: 28rpx;
  background: linear-gradient(145deg, #f6fbff 0%, #ffffff 54%, #f1f8ff 100%);
  box-shadow: inset 0 0 38rpx rgba(41, 131, 255, 0.05);
  overflow: hidden;
}

.success-weight-card::after {
  position: absolute;
  right: -90rpx;
  bottom: -54rpx;
  width: 300rpx;
  height: 150rpx;
  border: 1rpx solid rgba(69, 154, 255, 0.1);
  border-radius: 50%;
  content: "";
}

.success-weight-value {
  position: relative;
  z-index: 1;
  color: #0d73ff;
  font-weight: 800;
  line-height: 1;
  text-align: center;
}

.success-weight-value text:first-child {
  font-size: 104rpx;
  font-weight: 900;
  letter-spacing: 4rpx;
}

.success-weight-unit {
  margin-left: 12rpx;
  color: #101b2f;
  font-size: 34rpx;
  font-weight: 800;
}

.success-weight-label {
  position: relative;
  z-index: 1;
  margin-top: 14rpx;
  color: #778598;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
}

.success-bmi {
  position: relative;
  z-index: 1;
  left: 50%;
  transform: translateX(-50%);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  max-width: 100%;
  margin: 20rpx auto 0;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: #dceaff;
  color: #0f73ff;
  font-size: 24rpx;
  font-weight: 800;
  box-sizing: border-box;
}

.success-bmi.normal {
  background: #dcf7eb;
  color: #15a66e;
}

.success-stats {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

.success-stat-card {
  min-width: 0;
  min-height: 164rpx;
  padding: 20rpx 10rpx 16rpx;
  border: 1rpx solid #dfeeff;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #f9fcff 0%, #ffffff 100%);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.success-stat-card:nth-child(2) {
  border-color: #dff1e8;
  background: linear-gradient(180deg, #f8fffb 0%, #ffffff 100%);
}

.success-stat-card:nth-child(3) {
  border-color: #ffe8d0;
  background: linear-gradient(180deg, #fffaf5 0%, #ffffff 100%);
}

.success-stat-icon {
  width: 54rpx;
  height: 54rpx;
  margin-bottom: 12rpx;
  display: block;
}

.success-stat-label {
  color: #4c5a6d;
  font-size: 24rpx;
  line-height: 1.2;
}

.success-stat-text {
  min-width: 0;
  max-width: 100%;
  margin-top: 8rpx;
  color: #101b2f;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.15;
  white-space: nowrap;
}

.success-encourage {
  margin-top: 26rpx;
  color: #19a85e;
  font-size: 28rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.success-actions {
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.success-primary,
.success-secondary {
  height: 84rpx;
  margin: 0;
  border-radius: 42rpx;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 84rpx;
}

.success-primary {
  border: 0;
  background: linear-gradient(90deg, #0d6cff 0%, #0f83ff 100%);
  color: #ffffff;
  box-shadow: 0 14rpx 28rpx rgba(13, 108, 255, 0.28);
}

.success-secondary {
  border: 1rpx solid #167cff;
  background: #ffffff;
  color: #167cff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.success-share-icon {
  width: 36rpx;
  height: 34rpx;
  margin-right: 10rpx;
  display: block;
}

.success-footer-close {
  margin-top: 20rpx;
  color: #5e6673;
  font-size: 28rpx;
  line-height: 44rpx;
  text-align: center;
}

.onboarding-title {
  color: #1f2d3d;
  font-size: 40rpx;
  font-weight: 800;
  text-align: center;
  letter-spacing: 0;
}

.onboarding-desc {
  margin: 12rpx 0 28rpx;
  color: #7d8790;
  font-size: 26rpx;
  text-align: center;
}

.onboarding-form {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.form-row {
  height: 88rpx;
  padding: 0 22rpx;
  margin-top: 18rpx;
  border: 1rpx solid #e4ebf2;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.form-row text {
  color: #34495e;
  font-size: 28rpx;
}

.form-row input {
  flex: 1;
  margin-left: 24rpx;
  text-align: right;
  color: #1f2d3d;
  font-size: 28rpx;
}

.onboarding-field {
  height: 108rpx;
  margin-top: 0;
  padding: 0 22rpx;
  border: 1rpx solid #edf2f7;
  border-radius: 18rpx;
  background: #f8fbfe;
}

.field-copy {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.field-copy .field-label {
  color: #1f2d3d;
  font-size: 28rpx;
  font-weight: 700;
}

.field-copy .field-hint {
  margin-top: 6rpx;
