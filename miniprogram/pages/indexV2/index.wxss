  margin-top: 10rpx;
  padding-left: 0;
  font-size: 22rpx;
}

.progress-percent {
  font-size: 28rpx;
}

.middle-showcase .quick-actions {
  margin-top: 18rpx;
  gap: 12rpx;
}

.middle-showcase .quick-action {
  min-height: 116rpx;
  padding: 14rpx 10rpx 12rpx;
  border-radius: 22rpx;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  position: relative;
}

.middle-showcase .quick-icon-bubble {
  width: 58rpx;
  height: 58rpx;
  margin-right: 0;
  margin-bottom: 8rpx;
}

.middle-showcase .quick-icon {
  width: 44rpx;
  height: 44rpx;
}

.middle-showcase .quick-copy {
  width: 100%;
}

.middle-showcase .quick-title {
  font-size: 25rpx;
  white-space: nowrap;
}

.middle-showcase .quick-subtitle {
  margin-top: 5rpx;
  font-size: 20rpx;
  white-space: nowrap;
}

.middle-showcase .quick-arrow {
  position: absolute;
  right: 10rpx;
  bottom: 12rpx;
  font-size: 22rpx;
}

/* 统一上下节奏：中段不再做独立海报背景 */
.middle-showcase {
  margin: 8rpx 0 0;
  padding: 0;
  background: transparent;
  overflow: visible;
}

.middle-showcase::before,
.middle-showcase::after,
.middle-glow {
  display: none;
}

.middle-showcase .overview-card {
  border: 1rpx solid #eef3f8;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 26rpx rgba(32, 58, 84, 0.08);
}

.middle-showcase .overview-card::before {
  display: none;
}

.middle-showcase .quick-actions {
  margin-top: 18rpx;
  padding: 14rpx;
  border: 1rpx solid #eef3f8;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 26rpx rgba(32, 58, 84, 0.08);
  box-sizing: border-box;
}

.middle-showcase .quick-action {
  box-shadow: none;
  border: 0;
  border-radius: 18rpx;
}

.middle-showcase + .share-nudge,
.middle-showcase + .share-nudge + .trend-card,
.middle-showcase + .trend-card {
  margin-top: 18rpx;
}

/* 今日体重卡片间距美化：三列等宽、数值底部对齐、底部分隔更克制 */
.middle-showcase .overview-card {
  padding: 26rpx 24rpx 24rpx;
}

.middle-showcase .today-metrics {
  margin-top: 26rpx;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  align-items: stretch;
}

.middle-showcase .today-weight,
.middle-showcase .today-progress,
.middle-showcase .today-target {
  min-height: 116rpx;
  padding: 0 14rpx;
  display: flex;
  flex-direction: column;
}

.middle-showcase .today-weight {
  padding-left: 0;
}

.middle-showcase .today-target {
  padding-right: 0;
}

.middle-showcase .today-label {
  min-height: 30rpx;
  margin-bottom: 0;
  line-height: 30rpx;
}

.middle-showcase .weight-value,
.middle-showcase .loss-value,
.middle-showcase .target-value {
  margin-top: auto;
  padding-top: 10rpx;
  white-space: nowrap;
}

.middle-showcase .weight-value text:first-child,
.middle-showcase .loss-value text:first-child,
.middle-showcase .target-value text:first-child {
  font-size: 52rpx;
  line-height: 1;
}

.middle-showcase .weight-unit,
.middle-showcase .loss-unit,
.middle-showcase .target-unit {
  font-size: 22rpx;
}

.today-progress-footer {
  margin-top: 32rpx;
  padding-top: 0;
  border-top: 0;
}

/* 本月趋势头部图例 */
.trend-legend {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.legend-item {
  display: flex;
  align-items: center;
}

.legend-line {
  position: relative;
  width: 32rpx;
  height: 0;
  margin-right: 8rpx;
}

.legend-line.weight {
  border-top: 4rpx solid #167cff;
}

.legend-line.weight::after {
  content: "";
  position: absolute;
  top: 50%;
  left: 50%;
  width: 14rpx;
  height: 14rpx;
  border: 3rpx solid #167cff;
  border-radius: 50%;
  background: #ffffff;
  box-sizing: border-box;
  transform: translate(-50%, -50%);
}

.legend-line.target {
  border-top: 4rpx dashed #21c875;
}

.legend-text {
  color: #63718a;
  font-size: 22rpx;
}

/* 目标进度为负数（增重/偏离目标）时标红提示 */
.progress-percent.negative {
  color: #ff4f68;
}
