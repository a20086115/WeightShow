/* 弹层：新手引导、打卡、成功、BMI、分享 */

.onboarding-mask {
  position: fixed;
  z-index: 9999;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  padding: 40rpx 44rpx;
  background: rgba(20, 32, 45, 0.46);
  display: flex;
  align-items: center;
  justify-content: center;
}

.onboarding-card {
  position: relative;
  width: 100%;
  max-height: 92vh;
  padding: 42rpx 34rpx 34rpx;
  border-radius: 30rpx;
  background: #ffffff;
  box-sizing: border-box;
  overflow: hidden;
  box-shadow: 0 28rpx 60rpx rgba(24, 54, 87, 0.22);
}

.onboarding-accent {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 8rpx;
  background: linear-gradient(90deg, #188be4 0%, #20b7a7 58%, #ffb45f 100%);
}

.onboarding-badge {
  width: 128rpx;
  margin: 0 auto 16rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #eef7ff;
  color: #188be4;
  font-size: 22rpx;
  font-weight: 700;
}

.onboarding-title {
  color: #1f2d3d;
  font-size: 40rpx;
  font-weight: 800;
  text-align: center;
}

.onboarding-desc {
  margin: 12rpx 0 28rpx;
  color: #7d8790;
  font-size: 26rpx;
  text-align: center;
}

.onboarding-form {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.onboarding-field {
  height: 108rpx;
  margin-top: 0;
  padding: 0 22rpx;
  border: 1rpx solid #edf2f7;
  border-radius: 18rpx;
  background: #f8fbfe;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.field-copy {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.field-copy .field-label {
  color: #1f2d3d;
  font-size: 28rpx;
  font-weight: 700;
}

.field-copy .field-hint {
  margin-top: 6rpx;
  color: #9aa6b2;
  font-size: 22rpx;
}

.field-input {
  min-width: 210rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.field-input input {
  width: 150rpx;
  color: #1f2d3d;
  font-size: 32rpx;
  font-weight: 800;
  text-align: right;
}

.field-input text {
  margin-left: 8rpx;
  color: #7d8790;
  font-size: 24rpx;
}

.onboarding-reminder {
  margin-top: 22rpx;
}

.reminder-card {
  min-height: 104rpx;
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  background: #f3faf8;
  border: 1rpx solid #dff2ed;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.reminder-main {
  min-width: 0;
}

.reminder-title-row {
  display: flex;
  align-items: center;
  color: #1f2d3d;
  font-size: 28rpx;
  font-weight: 800;
}

.reminder-dot {
  width: 14rpx;
  height: 14rpx;
  margin-right: 12rpx;
  border-radius: 50%;
  background: #20b7a7;
  box-shadow: 0 0 0 8rpx rgba(32, 183, 167, 0.12);
}

.reminder-desc {
  margin-top: 8rpx;
  color: #7c908d;
  font-size: 23rpx;
}

.reminder-checkbox {
  margin-left: 20rpx;
}

.onboarding-time {
  min-height: 84rpx;
  margin-top: 14rpx;
  padding: 16rpx 20rpx;
  border: 1rpx solid #e2edf7;
  border-radius: 18rpx;
  background: #f7fbff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.onboarding-time .reminder-time-label {
  display: block;
  margin-right: 0;
  color: #657381;
  font-size: 23rpx;
}

.reminder-time-tip {
  display: block;
  margin-top: 4rpx;
  color: #1f2d3d;
  font-size: 27rpx;
  font-weight: 700;
}

.reminder-time-right {
  display: flex;
  align-items: center;
}

.onboarding-time .reminder-time-value {
  flex: none;
  color: #188be4;
  font-size: 28rpx;
  font-weight: 800;
}

.reminder-time-arrow {
  color: #969799;
  font-size: 32rpx;
}

.primary-action {
  height: 86rpx;
  margin-top: 30rpx;
  border: 0;
  border-radius: 43rpx;
  background: #188be4;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 86rpx;
  box-shadow: 0 12rpx 22rpx rgba(24, 139, 228, 0.24);
}

.helper-text {
  margin-top: 20rpx;
  color: #9aa6b2;
  font-size: 23rpx;
  text-align: center;
}

/* 打卡弹框 */
.checkin-mask {
  position: fixed;
  z-index: 100000;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  padding: 40rpx 44rpx;
  background: rgba(20, 32, 45, 0.48);
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkin-dialog-card {
  position: relative;
  width: 100%;
  max-height: 90vh;
  padding: 38rpx 32rpx 32rpx;
  border-radius: 30rpx;
  background: #ffffff;
  box-sizing: border-box;
  overflow-y: auto;
  box-shadow: 0 28rpx 60rpx rgba(24, 54, 87, 0.24);
}

.checkin-dialog-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.checkin-dialog-title {
  color: #1f2d3d;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.2;
}

.checkin-dialog-subtitle {
  margin-top: 10rpx;
  color: #8a97a3;
  font-size: 25rpx;
}

.checkin-dialog-badge {
  flex-shrink: 0;
  margin-top: 2rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #eef7ff;
  color: #188be4;
  font-size: 22rpx;
  font-weight: 700;
}

.checkin-input-grid {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 30rpx;
}

.checkin-input-card {
  min-width: 0;
  min-height: 112rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: #f3f9ff;
  border: 1rpx solid #e4f0fb;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.checkin-input-card.kg {
  background: #f8fbfe;
  border-color: #edf2f7;
}

.checkin-input-label {
  color: #7d8790;
  font-size: 24rpx;
  font-weight: 700;
}

.checkin-input-row {
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
  min-width: 0;
  flex: 1;
}

.checkin-input-row input {
  width: 280rpx;
  min-width: 0;
  color: #1f2d3d;
  font-size: 40rpx;
  font-weight: 800;
  text-align: right;
}

.checkin-input-row text {
  flex-shrink: 0;
  margin-left: 8rpx;
  color: #657381;
  font-size: 24rpx;
  font-weight: 700;
}

.checkin-extra {
  margin-top: 22rpx;
}

.checkin-extra-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.checkin-extra-title {
  color: #657381;
  font-size: 24rpx;
  font-weight: 800;
}

.checkin-tag-manage-button,
.tag-delete-button,
.tag-add-button {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  line-height: 1;
}

.checkin-tag-manage-button::after,
.tag-delete-button::after,
.tag-add-button::after {
  border: 0;
}

.checkin-tag-manage-button {
  gap: 6rpx;
  min-width: 100rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background: #eef6ff;
  color: #188be4;
  font-size: 22rpx;
  font-weight: 800;
}

.tag-manage-icon {
  font-size: 24rpx;
}

.checkin-tag-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.checkin-tag {
  padding: 10rpx 16rpx;
  border-radius: 16rpx;
  background: #f3f7fb;
  color: #657381;
  font-size: 24rpx;
  font-weight: 700;
}

.checkin-tag.active {
  background: #e7f3ff;
  color: #188be4;
}

.checkin-tag-manager {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 18rpx;
  background: #f8fbfe;
  border: 1rpx solid #edf2f7;
}

.tag-manager-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag-manager-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-height: 48rpx;
  padding: 0 10rpx 0 16rpx;
  border-radius: 24rpx;
  background: #ffffff;
  color: #465769;
  font-size: 22rpx;
  font-weight: 700;
  box-shadow: inset 0 0 0 1rpx #e6edf5;
}

.tag-delete-button {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #f1f5f9;
  color: #8a9aab;
  font-size: 20rpx;
}

.tag-add-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 14rpx;
}

.tag-add-input {
  flex: 1;
  height: 56rpx;
  padding: 0 18rpx;
  border-radius: 16rpx;
  background: #ffffff;
  color: #1f2d3d;
  font-size: 24rpx;
  box-shadow: inset 0 0 0 1rpx #e6edf5;
}

.tag-add-button {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: #188be4;
  color: #ffffff;
  font-size: 28rpx;
}

.checkin-note-card {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #f8fbfe;
  border: 1rpx solid #edf2f7;
}

.checkin-note-input {
  width: 100%;
  height: 112rpx;
  max-height: 112rpx;
  color: #1f2d3d;
  font-size: 26rpx;
  line-height: 1.5;
}

.checkin-image-card {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid #edf2f7;
  border-radius: 20rpx;
  background: #f8fbfe;
}

.checkin-image-add {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  min-width: 138rpx;
  height: 48rpx;
  margin: 0;
  padding: 0 14rpx;
  border: 0;
  border-radius: 24rpx;
  background: #eef6ff;
  color: #188be4;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 48rpx;
}

.checkin-image-add::after {
  border: 0;
}

.checkin-image-add-icon {
  font-size: 24rpx;
}

.checkin-image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 16rpx;
}

.checkin-image-item {
  position: relative;
  height: 156rpx;
  overflow: hidden;
  border-radius: 16rpx;
  background: #edf2f7;
}

.checkin-image-thumb {
  display: block;
  width: 100%;
  height: 100%;
}

.checkin-image-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: rgba(15, 23, 42, 0.72);
  color: #fff;
  font-size: 28rpx;
  line-height: 30rpx;
  text-align: center;
}

.checkin-reminder {
  margin-top: 18rpx;
}

.checkin-time {
  margin-top: 14rpx;
}

.checkin-actions {
  display: grid;
  grid-template-columns: 190rpx minmax(0, 1fr);
  gap: 18rpx;
  margin-top: 30rpx;
}

.secondary-checkin-action,
.primary-checkin-action {
  height: 82rpx;
  margin: 0;
  border: 0;
  border-radius: 41rpx;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 82rpx;
}

.secondary-checkin-action {
  background: #f2f6fa;
  color: #657381;
}

.primary-checkin-action {
  background: #188be4;
  color: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(24, 139, 228, 0.24);
}

/* 打卡成功弹框 */
.success-mask {
  position: fixed;
  z-index: 100003;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  padding: 92rpx 44rpx 40rpx;
  background: rgba(7, 18, 31, 0.66);
  display: flex;
  align-items: center;
  justify-content: center;
}

.success-dialog-card {
  position: relative;
  width: 100%;
  max-height: 88vh;
  padding: 112rpx 42rpx 30rpx;
  border: 1rpx solid rgba(219, 236, 255, 0.95);
  border-radius: 34rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
  box-sizing: border-box;
  overflow: visible;
  box-shadow: 0 34rpx 86rpx rgba(3, 18, 38, 0.3);
}

.success-hero-icon {
  position: absolute;
  top: -120rpx;
  left: 50%;
  z-index: 2;
  width: 270rpx;
  height: 214rpx;
  transform: translateX(-50%);
  display: block;
}

.success-close {
  position: absolute;
  top: 32rpx;
  right: 30rpx;
  width: 54rpx;
  height: 54rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 50%;
  background: #f7f9fb;
  color: #a0a8b4;
  font-size: 36rpx;
  line-height: 48rpx;
  text-align: center;
  box-sizing: border-box;
}

.success-title {
  color: #101b2f;
  font-size: 56rpx;
  font-weight: 900;
  line-height: 1.2;
  text-align: center;
}

.success-subtitle {
  margin-top: 10rpx;
  color: #738196;
  font-size: 28rpx;
  text-align: center;
}

.success-weight-card {
  position: relative;
  margin-top: 30rpx;
  padding: 34rpx 26rpx 32rpx;
  border: 1rpx solid #c7ddff;
  border-radius: 28rpx;
  background: linear-gradient(145deg, #f6fbff 0%, #ffffff 54%, #f1f8ff 100%);
  box-shadow: inset 0 0 38rpx rgba(41, 131, 255, 0.05);
  overflow: hidden;
}

.success-weight-card::after {
  position: absolute;
  right: -90rpx;
  bottom: -54rpx;
  width: 300rpx;
  height: 150rpx;
  border: 1rpx solid rgba(69, 154, 255, 0.1);
  border-radius: 50%;
  content: "";
}

.success-weight-value {
  position: relative;
  z-index: 1;
  color: #0d73ff;
  font-weight: 800;
  line-height: 1;
  text-align: center;
}

.success-weight-value text:first-child {
  font-size: 104rpx;
  font-weight: 900;
  letter-spacing: 4rpx;
}

.success-weight-unit {
  margin-left: 12rpx;
  color: #101b2f;
  font-size: 34rpx;
  font-weight: 800;
}

.success-weight-label {
  position: relative;
  z-index: 1;
  margin-top: 14rpx;
  color: #778598;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
}

.success-bmi {
  position: relative;
  z-index: 1;
  left: 50%;
  transform: translateX(-50%);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  max-width: 100%;
  margin: 20rpx auto 0;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: #dceaff;
  color: #0f73ff;
  font-size: 24rpx;
  font-weight: 800;
  box-sizing: border-box;
}

.success-bmi.normal {
  background: #dcf7eb;
  color: #15a66e;
}

.success-stats {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

.success-stat-card {
  min-width: 0;
  min-height: 164rpx;
  padding: 20rpx 10rpx 16rpx;
  border: 1rpx solid #dfeeff;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #f9fcff 0%, #ffffff 100%);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.success-stat-card:nth-child(2) {
  border-color: #dff1e8;
  background: linear-gradient(180deg, #f8fffb 0%, #ffffff 100%);
}

.success-stat-card:nth-child(3) {
  border-color: #ffe8d0;
  background: linear-gradient(180deg, #fffaf5 0%, #ffffff 100%);
}

.success-stat-icon {
  width: 54rpx;
  height: 54rpx;
  margin-bottom: 12rpx;
  display: block;
}

.success-stat-label {
  color: #4c5a6d;
  font-size: 24rpx;
  line-height: 1.2;
}

.success-stat-text {
  min-width: 0;
  max-width: 100%;
  margin-top: 8rpx;
  color: #101b2f;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.15;
  white-space: nowrap;
}

.success-encourage {
  margin-top: 26rpx;
  color: #19a85e;
  font-size: 28rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.success-actions {
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.success-primary,
.success-secondary {
  height: 84rpx;
  margin: 0;
  border-radius: 42rpx;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 84rpx;
}

.success-primary {
  border: 0;
  background: linear-gradient(90deg, #0d6cff 0%, #0f83ff 100%);
  color: #ffffff;
  box-shadow: 0 14rpx 28rpx rgba(13, 108, 255, 0.28);
}

.success-secondary {
  border: 1rpx solid #167cff;
  background: #ffffff;
  color: #167cff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.success-share-icon {
  width: 36rpx;
  height: 34rpx;
  margin-right: 10rpx;
  display: block;
}

.success-footer-close {
  margin-top: 20rpx;
  color: #5e6673;
  font-size: 28rpx;
  line-height: 44rpx;
  text-align: center;
}

/* BMI 弹框 */
.bmi-dialog-card {
  width: 100%;
  padding: 38rpx 34rpx 34rpx;
  border-radius: 24rpx;
  background: #fff;
  box-sizing: border-box;
}

.bmi-dialog-title {
  color: #1f2d3d;
  font-size: 36rpx;
  font-weight: 800;
  text-align: center;
}

.bmi-current {
  margin-top: 18rpx;
  color: #657381;
  font-size: 27rpx;
  text-align: center;
}

.bmi-current text {
  margin-left: 10rpx;
}

.bmi-current text:first-of-type {
  color: #ff5d6c;
  font-size: 38rpx;
  font-weight: 800;
}

.bmi-current text:first-of-type.normal {
  color: #15a675;
}

.bmi-range-bar {
  position: relative;
  margin: 42rpx 0 28rpx;
  padding-bottom: 72rpx;
}

.bmi-range-container {
  display: flex;
  height: 68rpx;
  overflow: hidden;
  border-radius: 34rpx;
  box-shadow: 0 8rpx 24rpx rgba(31, 45, 61, 0.12);
}

.bmi-range-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
}

.bmi-range-item.thin {
  background: #4da7ff;
}

.bmi-range-item.normal {
  background: #34c759;
}

.bmi-range-item.overweight {
  background: #ff9500;
}

.bmi-range-item.obese {
  background: #ff3b30;
}

.bmi-range-item text:first-child {
  font-size: 24rpx;
  font-weight: 700;
}

.bmi-range-item text:last-child {
  margin-top: 2rpx;
  font-size: 19rpx;
  opacity: 0.95;
}

.bmi-marker {
  position: absolute;
  top: 76rpx;
  z-index: 2;
  transform: translateX(-50%);
}

.bmi-marker-triangle {
  width: 0;
  height: 0;
  margin: 0 auto;
  border-left: 12rpx solid transparent;
  border-right: 12rpx solid transparent;
  border-bottom: 16rpx solid #188be4;
}

.bmi-marker-label {
  margin-top: 8rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #eaf6ff;
  color: #188be4;
  font-size: 20rpx;
  font-weight: 700;
  white-space: nowrap;
}

.bmi-text {
  padding: 22rpx;
  border-radius: 16rpx;
  background: #f6f9fc;
  color: #657381;
  font-size: 25rpx;
  line-height: 1.6;
}

/* 分享面板 */
.share-mask {
  position: fixed;
  z-index: 100002;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(20, 32, 45, 0.44);
  display: flex;
  align-items: flex-end;
}

.share-sheet {
  position: relative;
  width: 100%;
  padding: 18rpx 28rpx 34rpx;
  border-radius: 30rpx 30rpx 0 0;
  background: #ffffff;
  box-sizing: border-box;
  box-shadow: 0 -16rpx 44rpx rgba(24, 54, 87, 0.18);
}

.share-sheet-handle {
  width: 72rpx;
  height: 8rpx;
  margin: 0 auto 22rpx;
  border-radius: 999rpx;
  background: #d8e1ea;
}

.share-sheet-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.share-sheet-title {
  color: #1f2d3d;
  font-size: 36rpx;
  font-weight: 800;
}

.share-sheet-desc {
  margin-top: 8rpx;
  color: #657381;
  font-size: 25rpx;
}

.share-sheet-close {
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  background: #f2f6fa;
  color: #8a97a3;
  font-size: 36rpx;
  line-height: 50rpx;
  text-align: center;
}

.share-option-list {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.share-option {
  min-height: 112rpx;
  margin: 0;
  padding: 18rpx 20rpx;
  border: 1rpx solid #edf2f7;
  border-radius: 22rpx;
  background: #f8fbfe;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  text-align: left;
  line-height: normal;
}

.share-option-icon {
  flex-shrink: 0;
  width: 68rpx;
  height: 68rpx;
  margin-right: 18rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 34rpx;
}

.share-option-icon.friend {
  background: #188be4;
}

.share-option-icon.timeline {
  background: #20b7a7;
}

.share-option-copy {
  min-width: 0;
  flex: 1;
}

.share-option-title {
  color: #1f2d3d;
  font-size: 28rpx;
  font-weight: 800;
}

.share-option-desc {
  margin-top: 8rpx;
  color: #8a97a3;
  font-size: 23rpx;
}

.share-option-arrow {
  flex-shrink: 0;
  margin-left: 14rpx;
  color: #b0bac5;
  font-size: 28rpx;
}

.share-sheet-note {
  padding: 4rpx 8rpx 0;
  color: #9aa6b2;
  font-size: 22rpx;
  line-height: 1.5;
}

.monthly-target-dialog {
  padding: 34rpx 30rpx 28rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.monthly-target-title {
  color: #1f2d3d;
  font-size: 34rpx;
  font-weight: 800;
  text-align: center;
}

.monthly-target-subtitle {
  margin-top: 8rpx;
  color: #7a8799;
  font-size: 24rpx;
  text-align: center;
}

.monthly-target-input-row {
  height: 92rpx;
  margin-top: 28rpx;
  padding: 0 24rpx;
  border: 1rpx solid #dce7f2;
  border-radius: 8rpx;
  background: #f8fbfe;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.monthly-target-input {
  min-width: 0;
  flex: 1;
  height: 88rpx;
  color: #172033;
  font-size: 38rpx;
  font-weight: 800;
}

.monthly-target-unit {
  flex-shrink: 0;
  margin-left: 12rpx;
  color: #657381;
  font-size: 26rpx;
  font-weight: 700;
}

.monthly-target-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 28rpx;
}

.monthly-target-cancel,
.monthly-target-save {
  height: 76rpx;
  margin: 0;
  border: 0;
  border-radius: 8rpx;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 76rpx;
}

.monthly-target-cancel::after,
.monthly-target-save::after {
  border: 0;
}

.monthly-target-cancel {
  background: #f1f5f9;
  color: #657381;
}

.monthly-target-save {
  background: #188be4;
  color: #ffffff;
}
