/* 页面骨架：日历、趋势图、分享引导 */

.page {
  min-height: 100vh;
  padding: 18rpx 22rpx 40rpx;
  background: #f6f8fb;
  box-sizing: border-box;
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  width: 100vw;
  margin: 0;
  background: #188be4;
  box-sizing: border-box;
}

.custom-nav-spacer {
  width: 100%;
}

.custom-nav-title {
  position: absolute;
  left: 44rpx;
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 900;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.favorite-entry {
  position: absolute;
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 800;
  box-shadow: 0 8rpx 22rpx rgba(16, 74, 120, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 5rpx;
}

.favorite-star {
  color: #ffffff;
  font-size: 30rpx;
  line-height: 1;
}

.calendar-section {
  margin-top: 8rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-title {
  color: #21304a;
  font-size: 30rpx;
  font-weight: 700;
}

.trend-card {
  margin-top: 18rpx;
  padding: 24rpx 24rpx 20rpx;
  background: #ffffff;
  border: 1rpx solid #eef3f8;
  border-radius: 24rpx;
  box-shadow: 0 12rpx 26rpx rgba(32, 58, 84, 0.08);
  box-sizing: border-box;
}

.trend-title-wrap {
  display: flex;
  align-items: center;
}

.trend-title-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 12rpx;
}

.trend-card .card-title {
  color: #071436;
  font-size: 34rpx;
  font-weight: 800;
}

.trend-legend {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.legend-item {
  display: flex;
  align-items: center;
}

.legend-line {
  position: relative;
  width: 32rpx;
  height: 0;
  margin-right: 8rpx;
}

.legend-line.weight {
  border-top: 4rpx solid #167cff;
}

.legend-line.weight::after {
  content: "";
  position: absolute;
  top: 50%;
  left: 50%;
  width: 14rpx;
  height: 14rpx;
  border: 3rpx solid #167cff;
  border-radius: 50%;
  background: #ffffff;
  box-sizing: border-box;
  transform: translate(-50%, -50%);
}

.legend-line.target {
  border-top: 4rpx dashed #21c875;
}

.legend-text {
  color: #63718a;
  font-size: 22rpx;
}

.chart-box {
  height: 360rpx;
  margin-top: 8rpx;
}

.chart-box ec-canvas {
  width: 100%;
  height: 100%;
}

.chart-hidden-placeholder {
  width: 100%;
  height: 100%;
}

.chart-empty {
  height: 260rpx;
  color: #9aa6b2;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.favorite-guide-mask {
  position: fixed;
  z-index: 100004;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  padding: 250rpx 34rpx 44rpx;
  background: rgba(0, 0, 0, 0.52);
  box-sizing: border-box;
}

.favorite-guide-arrow {
  position: fixed;
  z-index: 2;
  width: 92rpx;
  height: 92rpx;
  color: #ffffff;
  font-size: 86rpx;
  font-weight: 900;
  line-height: 92rpx;
  text-align: center;
  transform: rotate(-18deg);
  text-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.24);
}

.favorite-guide-card {
  position: relative;
  padding: 34rpx 28rpx 30rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.92);
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.12);
  box-sizing: border-box;
  backdrop-filter: blur(4px);
}

.favorite-guide-title {
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.35;
  text-align: center;
}

.favorite-guide-tip {
  margin-top: 18rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.6;
  text-align: center;
}

.favorite-guide-steps {
  margin-top: 30rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18rpx;
}

.favorite-guide-step {
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.favorite-step-icon {
  width: 74rpx;
  height: 74rpx;
  border: 4rpx solid #ffffff;
  border-radius: 50%;
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 66rpx;
  text-align: center;
  box-sizing: border-box;
}

.favorite-step-text {
  margin-top: 14rpx;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.25;
  text-align: center;
}

.favorite-guide-action {
  height: 82rpx;
  margin: 42rpx auto 0;
  padding: 0 42rpx;
  border: 4rpx dashed rgba(255, 255, 255, 0.9);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.1);
  color: #ffffff;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 74rpx;
}

.share-nudge {
  min-height: 112rpx;
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
  border-radius: 22rpx;
  background: #f3faf8;
  border: 1rpx solid #dff2ed;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.share-nudge-copy {
  min-width: 0;
}

.share-nudge-title {
  color: #1f2d3d;
  font-size: 27rpx;
  font-weight: 800;
}

.share-nudge-desc {
  margin-top: 6rpx;
  color: #6d8a85;
  font-size: 23rpx;
}

.share-nudge-actions {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.nudge-primary,
.nudge-secondary {
  height: 58rpx;
  margin: 0;
  padding: 0 18rpx;
  border: 0;
  border-radius: 29rpx;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 58rpx;
}

.nudge-primary {
  background: #167cff;
  color: #ffffff;
  box-shadow: 0 8rpx 16rpx rgba(22, 124, 255, 0.18);
}

.nudge-secondary {
  background: #ffffff;
  color: #7d8790;
}

.join-group-dialog {
  max-height: 850rpx;
  overflow: scroll;
}

.join-group-image {
  width: 100%;
  display: block;
}

.month-up {
  color: #ff4f68;
}

.month-down {
  color: #18ad73;
}

.progress-percent.negative {
  color: #ff4f68;
}

/* 去除小程序 button 默认边框 */
.checkin-btn::after,
.share-option::after,
.nudge-primary::after,
.nudge-secondary::after,
.favorite-entry::after,
.favorite-guide-action::after,
.primary-action::after,
.primary-checkin-action::after,
.secondary-checkin-action::after,
.success-primary::after,
.success-secondary::after,
.quick-action::after {
  border: 0;
}
