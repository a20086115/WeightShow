/* indexV2 showcase - design ref, 1px ~= 1rpx */

.middle-showcase {
  margin: 8rpx 0 0;
  padding: 0;
  background: transparent;
  overflow: visible;
}

.middle-showcase::before,
.middle-showcase::after,
.middle-glow {
  display: none;
}

.card-sparkle {
  display: none;
}

.middle-showcase .overview-card {
  position: relative;
  z-index: 1;
  margin-top: 20rpx;
  padding: 24rpx;
  border: 0;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
  box-shadow: 0 28rpx 72rpx rgba(32, 80, 150, 0.1);
  box-sizing: border-box;
  overflow: hidden;
}

.middle-showcase .today-card-head,
.middle-showcase .today-metrics,
.middle-showcase .today-progress-footer {
  position: relative;
  z-index: 2;
}

.today-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 34rpx;
}

.today-title-wrap {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.middle-showcase .today-title-icon {
  flex-shrink: 0;
  width: 40rpx;
  height: 40rpx;
  padding: 6rpx;
  border: 4rpx solid #2878ff;
  border-radius: 10rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.middle-showcase .today-title {
  color: #071538;
  font-size: 34rpx;
  font-weight: 800;
  letter-spacing: 0.5rpx;
  white-space: nowrap;
}

.checkin-btn {
  flex-shrink: 0;
  height: 48rpx;
  margin: 0;
  padding: 0 26rpx;
  border: 0;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #4388ff 0%, #0066f7 100%);
  color: #ffffff;
  box-shadow: 0 10rpx 20rpx rgba(18, 102, 255, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1;
}

.checkin-btn-icon {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #ffffff;
  color: #1672ff;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 28rpx;
  text-align: center;
  flex-shrink: 0;
}

.checkin-btn.checked {
  background: linear-gradient(135deg, #2fd383 0%, #19b86b 100%);
  box-shadow: 0 20rpx 40rpx rgba(32, 183, 118, 0.22);
}

.checkin-btn.checked .checkin-btn-icon {
  color: #19b86b;
}

.checkin-plus {
  display: none;
}

.middle-showcase .today-metrics {
  margin-top: 0;
  margin-bottom: 14rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  align-items: stretch;
}

.middle-showcase .today-weight,
.middle-showcase .today-progress,
.middle-showcase .today-target {
  min-width: 0;
  min-height: 116rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  text-align: left;
}

.middle-showcase .today-weight {
  padding-left: 0;
  padding-right: 18rpx;
}

.middle-showcase .today-progress {
  border-left: 2rpx solid #e6edf6;
  border-right: 2rpx solid #e6edf6;
}

.middle-showcase .today-target {
  padding-right: 0;
  padding-left: 18rpx;
}

.middle-showcase .today-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  color: #7b879d;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.2;
  white-space: nowrap;
}

.target-label {
  gap: 6rpx;
}

.target-edit-icon {
  color: #a7b0c2;
  font-size: 18rpx;
}

.middle-showcase .weight-value,
.middle-showcase .loss-value,
.middle-showcase .target-value {
  padding-top: 8rpx;
  white-space: nowrap;
}

.weight-value text:first-child,
.loss-value text:first-child,
.target-value text:first-child {
  color: #071538;
  font-size: 48rpx;
  line-height: 1;
  font-weight: 900;
}

.weight-unit,
.loss-unit,
.target-unit {
  margin-left: 6rpx;
  color: #5e6a7f;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.loss-value {
  color: #18bd61;
}

.loss-value.month-up,
.loss-value.month-up text:first-child {
  color: #ff3f66;
}

.today-progress-footer {
  margin-top: 0;
  padding-top: 0;
  border-top: 0;
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 2fr);
  column-gap: 20rpx;
  align-items: center;
}

.today-chip-row {
  margin-top: 0;
  min-width: 0;
}

.middle-showcase .bmi-pill {
  width: 100%;
  height: 72rpx;
  margin-top: 0;
  padding: 0 12rpx;
  border: 2rpx solid #d9e8ff;
  border-radius: 999rpx;
  background: #ffffff;
  color: #2878ff;
  font-size: 20rpx;
  font-weight: 800;
  box-shadow: 0 16rpx 36rpx rgba(41, 112, 255, 0.08);
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
}

.bmi-divider {
  margin: 0 6rpx;
  color: #2878ff;
}

.bmi-status-inline {
  color: #ff6a22;
  font-weight: 800;
}

.bmi-pill.normal .bmi-status-inline {
  color: #18ad73;
}

.bmi-arrow {
  margin-left: 6rpx;
  font-size: 26rpx;
  color: #2878ff;
  flex-shrink: 0;
}

.progress-inline {
  min-width: 0;
}

.progress-track {
  height: 20rpx;
  margin-top: 0;
  margin-bottom: 18rpx;
  border-radius: 999rpx;
  background: #e9eef6;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  min-width: 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #18bd61 0%, #32d276 100%);
}

.progress-meta {
  margin-top: 0;
  color: #6d7890;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
}

.progress-percent {
  margin-left: 8rpx;
  color: #18a94d;
  font-size: 30rpx;
  font-weight: 900;
}

.progress-percent.negative {
  color: #ff3f66;
}

.progress-remain {
  color: #69758c;
  flex-shrink: 0;
  white-space: nowrap;
}

.middle-showcase .quick-actions {
  margin-top: 18rpx;
  padding: 0;
  border: 0;
  background: transparent;
  box-shadow: none;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.middle-showcase .quick-action {
  min-height: 118rpx;
  margin: 0;
  padding: 20rpx 16rpx;
  border: 0;
  border-radius: 22rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 14rpx;
  text-align: left;
  overflow: hidden;
  box-shadow:
    0 10rpx 26rpx rgba(35, 73, 130, 0.08),
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.9);
}

.quick-action.ai {
  background: linear-gradient(135deg, #f2f8ff 0%, #ffffff 100%);
}

.quick-action.group {
  background: linear-gradient(135deg, #f0fff4 0%, #ffffff 100%);
}

.quick-action.share {
  background: linear-gradient(135deg, #fff5ea 0%, #ffffff 100%);
}

.middle-showcase .quick-icon-bubble {
  flex-shrink: 0;
  width: 54rpx;
  height: 54rpx;
  margin: 0;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 18rpx rgba(45, 91, 160, 0.08);
}

.ai .quick-icon-bubble {
  box-shadow: 0 8rpx 18rpx rgba(22, 124, 255, 0.12);
}

.group .quick-icon-bubble {
  box-shadow: 0 8rpx 18rpx rgba(32, 183, 118, 0.12);
}

.share .quick-icon-bubble {
  box-shadow: 0 8rpx 18rpx rgba(255, 138, 42, 0.12);
}

.middle-showcase .quick-icon {
  width: 30rpx;
  height: 30rpx;
  margin: 0;
}

.middle-showcase .quick-copy {
  flex: 1;
  min-width: 0;
}

.middle-showcase .quick-title {
  margin-bottom: 6rpx;
  color: #071538;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.middle-showcase .quick-subtitle {
  margin-top: 0;
  color: #404856;
  font-size: 22rpx;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.middle-showcase + .share-nudge,
.middle-showcase + .share-nudge + .trend-card,
.middle-showcase + .trend-card {
  margin-top: 18rpx;
}
