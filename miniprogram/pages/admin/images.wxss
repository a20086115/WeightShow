page {
  background: #f4f7fb;
  color: #172033;
}

.admin-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  box-sizing: border-box;
}

.filter-panel,
.empty-card {
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(31, 54, 86, 0.07);
}

.filter-panel {
  padding: 24rpx;
}

.filter-title {
  font-size: 30rpx;
  font-weight: 800;
}

.filter-row {
  margin-top: 16rpx;
}

.filter-input {
  height: 72rpx;
  padding: 0 18rpx;
  border-radius: 8rpx;
  background: #f7fafc;
  color: #172033;
  font-size: 25rpx;
  box-sizing: border-box;
}

.filter-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 18rpx;
}

.primary-button,
.secondary-button,
.load-more {
  height: 68rpx;
  margin: 0;
  border: 0;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 68rpx;
}

.primary-button::after,
.secondary-button::after,
.load-more::after {
  border: 0;
}

.primary-button {
  background: #188be4;
  color: #ffffff;
}

.secondary-button {
  background: #f1f5f9;
  color: #657381;
}

.list-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
  margin: 28rpx 4rpx 16rpx;
}

.page-title {
  font-size: 34rpx;
  font-weight: 800;
}

.page-subtitle {
  margin-top: 6rpx;
  color: #7a8799;
  font-size: 24rpx;
}

.total-chip {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 8rpx;
  background: #e8f4ff;
  color: #188be4;
  font-size: 22rpx;
  font-weight: 700;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
}

.image-card {
  position: relative;
  overflow: hidden;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(31, 54, 86, 0.07);
}

.image-thumb {
  display: block;
  width: 100%;
  height: 164rpx;
  background: #edf2f7;
}

.image-meta {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  padding: 18rpx 8rpx 8rpx;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0), rgba(0, 0, 0, 0.58));
}

.image-date {
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.image-user,
.image-field {
  display: none;
}

.empty-card {
  margin-top: 20rpx;
  padding: 68rpx 0;
  color: #94a3b8;
  font-size: 26rpx;
  text-align: center;
}

.load-more {
  width: 220rpx;
  margin: 26rpx auto 0;
  background: #e8f4ff;
  color: #188be4;
}

.end-text {
  padding: 28rpx 0 0;
  color: #94a3b8;
  font-size: 23rpx;
  text-align: center;
}
