page {
  background: #f4f7fb;
  color: #172033;
}

.admin-page {
  min-height: 100vh;
  padding: 28rpx 24rpx 48rpx;
  box-sizing: border-box;
}

.admin-header {
  padding: 30rpx 28rpx;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(31, 54, 86, 0.08);
}

.admin-title {
  font-size: 40rpx;
  font-weight: 800;
}

.admin-subtitle {
  margin-top: 8rpx;
  color: #7a8799;
  font-size: 24rpx;
}

.module-list {
  margin-top: 22rpx;
}

.module-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 132rpx;
  margin-top: 16rpx;
  padding: 24rpx;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(31, 54, 86, 0.08);
  box-sizing: border-box;
}

.module-icon {
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #e8f4ff;
  color: #188be4;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 72rpx;
  text-align: center;
}

.module-icon.image {
  background: #eef9f5;
  color: #16a06c;
}

.module-main {
  flex: 1;
  min-width: 0;
}

.module-title {
  font-size: 30rpx;
  font-weight: 800;
}

.module-desc {
  margin-top: 8rpx;
  color: #7a8799;
  font-size: 24rpx;
}

.module-arrow {
  color: #9aa6b2;
  font-size: 44rpx;
}
