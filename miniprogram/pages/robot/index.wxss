/* pages/robot/index.wxss */
.container {
  padding: 0;
  background: linear-gradient(180deg, #f5f7fa 0%, #f0f2f5 100%);
  min-height: 100vh;
}

.section {
  background: white;
  border-radius: 0;
  padding: 0;
  margin-bottom: 20rpx;
  box-shadow: none;
  overflow: hidden;
}

.section:first-of-type {
  margin-top: 20rpx;
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  padding: 32rpx 30rpx 24rpx;
  color: #1a1a1a;
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: white;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-icon {
  font-size: 32rpx;
  line-height: 1;
}

.feature-list {
  display: flex;
  flex-direction: column;
  gap: 0;
  padding: 0 30rpx 24rpx;
  background: white;
}

.feature-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.feature-item:last-child {
  border-bottom: none;
}

.feature-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.08) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.feature-icon {
  font-size: 40rpx;
}

.feature-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.feature-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.feature-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  font-weight: 300;
}

/* 个人绑定：机器人微信号 */
.wechat-id-row {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  gap: 20rpx;
  background: white;
}
.wechat-id-label {
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
}
.wechat-id-value {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  word-break: break-all;
}
.copy-wechat-btn {
  flex-shrink: 0;
}
.wechat-id-tip {
  font-size: 24rpx;
  color: #999;
  padding: 0 30rpx 16rpx;
  line-height: 1.5;
  background: white;
}

.bind-guide {
  padding: 0 30rpx 24rpx;
  background: white;
}

.guide-text {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.guide-steps {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.guide-step-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.step-number {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.guide-step {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  flex: 1;
}

.copy-btn {
  width: calc(100% - 60rpx);
  margin: 0 30rpx 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.2);
}

.bind-message-container {
  padding: 0 30rpx 24rpx;
  background: white;
}

.bind-message-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
  font-weight: 300;
}

.bind-message-box {
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  border: 1rpx solid #e8e8e8;
}

.bind-message {
  display: block;
  font-size: 28rpx;
  color: #1a1a1a;
  text-align: center;
  word-break: break-all;
  font-weight: 500;
}

.tip-section {
  text-align: center;
  padding: 24rpx 30rpx;
  margin-top: 20rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #999;
  font-weight: 300;
}

/* 绑定卡片样式 */
.binding-card {
  margin: 0 30rpx 20rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.05) 0%, rgba(118, 75, 162, 0.03) 100%);
  border-radius: 16rpx;
  border: 1rpx solid rgba(102, 126, 234, 0.1);
}

.binding-card:last-child {
  margin-bottom: 24rpx;
}

.binding-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.binding-name {
  font-size: 32rpx;
  color: #1a1a1a;
  font-weight: 600;
}

.binding-status-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 16rpx;
  background: rgba(82, 196, 26, 0.1);
  border-radius: 20rpx;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #52c41a;
}

.binding-status-text {
  font-size: 24rpx;
  color: #52c41a;
  font-weight: 500;
}

.binding-card-footer {
  display: flex;
  justify-content: flex-end;
}

.unbind-section {
  padding: 30rpx;
  background: transparent;
}

.unbind-btn-wrapper {
  margin-top: 20rpx;
}

.unbind-btn-wrapper:first-child {
  margin-top: 0;
}

/* 按钮样式优化 */
.van-button--primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.25);
}

.van-button--danger.van-button--plain {
  border-color: #ee4d4d;
  color: #ee4d4d;
  background: white;
}

.van-button--danger.van-button--plain:active {
  background: #fff5f5;
}
