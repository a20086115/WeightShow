/* 群绑定说明页 */
.container {
  padding: 20rpx 0;
  background: linear-gradient(180deg, #f5f7fa 0%, #f0f2f5 100%);
  min-height: 100vh;
}

.section {
  background: white;
  margin: 0 24rpx 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  padding: 32rpx 30rpx 24rpx;
  color: #1a1a1a;
  display: flex;
  align-items: center;
  gap: 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-icon {
  font-size: 32rpx;
}

/* 微信号区域 */
.wechat-section .wechat-id-row {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  gap: 20rpx;
}

.wechat-id-label {
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
}

.wechat-id-value {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  word-break: break-all;
}

.copy-wechat-btn {
  flex-shrink: 0;
}

.wechat-tip {
  font-size: 24rpx;
  color: #999;
  padding: 0 30rpx 24rpx;
  line-height: 1.5;
}

/* 步骤 */
.guide-steps {
  padding: 24rpx 30rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.guide-step-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.step-number {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.guide-step {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.guide-step .highlight {
  color: #667eea;
  font-weight: 600;
}

/* 绑定消息 */
.bind-message-box {
  margin: 24rpx 30rpx;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  border: 1rpx solid #e8e8e8;
}

.bind-message {
  display: block;
  font-size: 30rpx;
  color: #1a1a1a;
  text-align: center;
  word-break: break-all;
  font-weight: 500;
}

.copy-btn {
  width: calc(100% - 60rpx);
  margin: 0 30rpx 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.2);
}
