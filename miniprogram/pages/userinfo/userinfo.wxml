<view class="pageContainer">
  <view class="profile-hero">
    <view class="hero-copy">
      <view class="hero-kicker">个人资料</view>
      <view class="hero-title">{{ currentUser.nickName || '健康档案' }}</view>
      <view class="hero-subtitle">目标管理 · 身体数据 · 打卡状态</view>
    </view>
    <button class="avatar-wrapper" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
      <image wx:if="{{ currentUser.avatarUrl }}" class="avatar" src="{{ currentUser.avatarUrl }}" mode="aspectFill"></image>
      <view wx:else class="avatar-placeholder">
        <text class="cuIcon-cameraadd"></text>
      </view>
      <view class="avatar-edit">更换</view>
    </button>
  </view>

  <view class="metric-strip">
    <view class="metric-item">
      <view class="metric-value">{{ currentUser.height || '--' }}</view>
      <view class="metric-label">身高 cm</view>
    </view>
    <view class="metric-divider"></view>
    <view class="metric-item">
      <view class="metric-value">{{ currentUser.aimWeightKg || '--' }}</view>
      <view class="metric-label">目标 kg</view>
    </view>
    <view class="metric-divider"></view>
    <view class="metric-item">
      <view class="metric-value">{{ currentUser.bmi || '--' }}</view>
      <view class="metric-label">当前 BMI</view>
    </view>
  </view>

  <view class="form-section">
    <view class="section-head">
      <view>
        <view class="section-title">基础信息</view>
        <view class="section-desc">必填资料</view>
      </view>
    </view>
    <van-cell-group custom-class="profile-cell-group">
      <van-field custom-class="profile-field" title-width="120px" type="nickname" id="nickName" value="{{ currentUser.nickName }}" bind:change="onValueChange" clearable label="昵称" placeholder="请输入昵称" />
      <van-field custom-class="profile-field" title-width="120px" id="age" value="{{ currentUser.age }}" clearable label="年龄" placeholder="请输入年龄" bind:change="onValueChange" />
      <van-field custom-class="profile-field" title-width="120px" id="height" value="{{ currentUser.height }}" clearable label="身高（厘米）" placeholder="请输入身高（厘米）" bind:change="onValueChange" />
    </van-cell-group>
  </view>

  <view class="form-section">
    <view class="section-head">
      <view>
        <view class="section-title">目标设置</view>
        <view class="section-desc">自动换算</view>
      </view>
    </view>
    <van-cell-group custom-class="profile-cell-group">
      <van-field custom-class="profile-field" title-width="120px" id="aimWeightKg" value="{{ currentUser.aimWeightKg }}" clearable label="目标体重（公斤）" type="number" placeholder="请输入目标体重（公斤）" bind:change="onValueChange" />
      <van-field custom-class="profile-field" title-width="120px" id="aimWeight" value="{{ currentUser.aimWeight }}" clearable label="目标体重（斤）" type="number" placeholder="请输入目标体重（斤）" bind:change="onValueChange" />
      <van-field custom-class="profile-field readonly-field" title-width="120px" id="aimBmi" value="{{ currentUser.aimBmi }}" disabled="true" label="目标BMI" type="number" placeholder="根据目标体重自动计算" />
    </van-cell-group>
  </view>

  <view class="form-section">
    <view class="section-head">
      <view>
        <view class="section-title">打卡提醒</view>
        <view class="section-desc">固定你的日常提醒习惯</view>
      </view>
    </view>
    <view class="reminder-setting-card">
      <view class="reminder-setting-copy">
        <view class="reminder-setting-title">明天提醒我打卡</view>
        <view class="reminder-setting-desc">{{ reminderEnabled ? '打卡时会默认预约明天提醒' : '打卡时默认不预约提醒' }}</view>
      </view>
      <switch color="#188be4" checked="{{reminderEnabled}}" bindchange="onReminderEnabledChange" />
    </view>
    <picker wx:if="{{reminderEnabled}}" mode="time" value="{{reminderTime || defaultReminderTime}}" bindchange="onReminderTimeChange">
      <view class="reminder-time-row">
        <view>
          <view class="reminder-time-label">默认提醒时间</view>
          <view class="reminder-time-desc">打卡弹窗会自动带出这个时间</view>
        </view>
        <view class="reminder-time-value">{{ reminderTime || defaultReminderTime }}</view>
      </view>
    </picker>
  </view>

  <view class="form-section">
    <view class="section-head">
      <view>
        <view class="section-title">当前状态</view>
        <view class="section-desc">最近打卡</view>
      </view>
    </view>
    <van-cell-group custom-class="profile-cell-group">
      <van-field custom-class="profile-field readonly-field" title-width="120px" id="lastWeightKg" value="{{ currentUser.weightKg }}" disabled="true" clearable label="当前体重（公斤）" type="number" placeholder="请在首页打卡" bind:change="onValueChange" />
      <van-field custom-class="profile-field readonly-field" title-width="120px" id="lastWeight" value="{{ currentUser.weight }}" disabled="true" clearable label="当前体重（斤）" type="number" placeholder="请在首页打卡" bind:change="onValueChange" />
      <van-field custom-class="profile-field readonly-field" title-width="120px" id="bmi" value="{{ currentUser.bmi }}" disabled="true" label="当前BMI" type="number" />
    </van-cell-group>
  </view>

  <view class="save-bar">
    <view class="save-action">
      <view class="save-action-copy">
        <view class="save-action-title">资料确认无误</view>
        <view class="save-action-desc">保存后同步到健康档案</view>
      </view>
      <van-button custom-class="save-button" type="info" size="large" bindtap="saveData">
        <view class="save-button-inner">
          <text class="save-button-text">保存资料</text>
        </view>
      </van-button>
    </view>
  </view>
  <van-toast id="van-toast" />
</view>
