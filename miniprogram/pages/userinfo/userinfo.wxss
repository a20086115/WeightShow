page {
  min-height: 100vh;
  background: #f5f8fb;
}

.pageContainer {
  min-height: 100vh;
  padding: 24rpx 24rpx 204rpx;
  box-sizing: border-box;
}

.profile-hero {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 236rpx;
  padding: 34rpx 30rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #188be4 0%, #20b4c8 100%);
  box-shadow: 0 14rpx 34rpx rgba(24, 139, 228, 0.22);
  overflow: hidden;
  box-sizing: border-box;
}

.profile-hero::after {
  content: "";
  position: absolute;
  right: -88rpx;
  bottom: -96rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.16);
}

.hero-copy {
  position: relative;
  z-index: 1;
  flex: 1;
  min-width: 0;
  padding-right: 28rpx;
}

.hero-kicker {
  display: inline-flex;
  align-items: center;
  height: 38rpx;
  padding: 0 16rpx;
  border-radius: 19rpx;
  background: rgba(255, 255, 255, 0.18);
  color: rgba(255, 255, 255, 0.92);
  font-size: 22rpx;
}

.hero-title {
  margin-top: 18rpx;
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 48rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hero-subtitle {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 24rpx;
  line-height: 34rpx;
}

.avatar-wrapper {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 142rpx;
  height: 142rpx;
  padding: 0;
  margin: 0;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 10rpx 26rpx rgba(0, 0, 0, 0.14);
  overflow: hidden;
}

.avatar-wrapper::after {
  border: 0;
}

.avatar-wrapper:active {
  transform: scale(0.97);
}

.avatar {
  width: 142rpx;
  height: 142rpx;
  border-radius: 50%;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 142rpx;
  height: 142rpx;
  color: #188be4;
  font-size: 46rpx;
}

.avatar-edit {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 40rpx;
  background: rgba(31, 45, 61, 0.62);
  color: #ffffff;
  font-size: 20rpx;
  line-height: 40rpx;
  text-align: center;
}

.metric-strip {
  display: flex;
  align-items: center;
  margin: 24rpx 0 26rpx;
  padding: 24rpx 8rpx;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(24, 139, 228, 0.07);
}

.metric-item {
  flex: 1;
  min-width: 0;
  text-align: center;
}

.metric-value {
  color: #1f2d3d;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 42rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.metric-label {
  margin-top: 8rpx;
  color: #8a97a3;
  font-size: 22rpx;
}

.metric-divider {
  width: 1rpx;
  height: 48rpx;
  background: #edf2f6;
}

.form-section {
  margin-top: 24rpx;
  padding: 26rpx 0 4rpx;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(24, 139, 228, 0.07);
  overflow: hidden;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28rpx 18rpx;
}

.section-title {
  color: #1f2d3d;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 40rpx;
}

.section-desc {
  margin-top: 6rpx;
  color: #8a97a3;
  font-size: 23rpx;
  line-height: 32rpx;
}

.profile-cell-group {
  overflow: hidden;
}

.profile-field {
  --cell-background-color: #ffffff;
  --cell-vertical-padding: 18rpx;
  --cell-horizontal-padding: 28rpx;
  --field-label-color: #4d5b68;
  --field-input-text-color: #1f2d3d;
  --field-placeholder-text-color: #b6c0c9;
  --field-disabled-text-color: #657381;
}

.readonly-field {
  --cell-background-color: #fbfcfe;
}

.reminder-setting-card,
.reminder-time-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 28rpx 20rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #fbfcfe;
  box-sizing: border-box;
}

.reminder-setting-copy {
  flex: 1;
  min-width: 0;
  padding-right: 20rpx;
}

.reminder-setting-title,
.reminder-time-label {
  color: #1f2d3d;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 38rpx;
}

.reminder-setting-desc,
.reminder-time-desc {
  margin-top: 8rpx;
  color: #8a97a3;
  font-size: 23rpx;
  line-height: 32rpx;
}

.reminder-time-row {
  margin-top: 0;
  background: #eef7ff;
}

.reminder-time-value {
  flex-shrink: 0;
  min-width: 118rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #188be4;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 36rpx;
  text-align: center;
  box-shadow: 0 6rpx 18rpx rgba(24, 139, 228, 0.1);
}

.save-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(245, 248, 251, 0.72) 0%, rgba(245, 248, 251, 0.98) 34%, #f5f8fb 100%);
  box-sizing: border-box;
}

.save-bar::before {
  content: "";
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  top: 0;
  height: 1rpx;
  background: rgba(24, 139, 228, 0.08);
}

.save-action {
  display: flex;
  align-items: center;
  padding: 18rpx;
  border: 1rpx solid rgba(24, 139, 228, 0.08);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 16rpx 36rpx rgba(31, 45, 61, 0.1);
  box-sizing: border-box;
}

.save-action-copy {
  flex: 1;
  min-width: 0;
  padding-left: 4rpx;
}

.save-action-title {
  color: #1f2d3d;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 36rpx;
}

.save-action-desc {
  margin-top: 4rpx;
  color: #8a97a3;
  font-size: 22rpx;
  line-height: 30rpx;
}

.save-button {
  margin-left: 20rpx;
  width: 232rpx;
  height: 82rpx;
  border: 0;
  border-radius: 41rpx;
  background: linear-gradient(135deg, #1597ed 0%, #18c2c2 100%);
  box-shadow: 0 14rpx 28rpx rgba(24, 139, 228, 0.28);
  overflow: hidden;
}

.save-button:active {
  transform: translateY(2rpx);
  box-shadow: 0 8rpx 18rpx rgba(24, 139, 228, 0.22);
}

.save-button-inner {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 82rpx;
}

.save-button-inner::before {
  content: "";
  position: absolute;
  left: 22rpx;
  right: 22rpx;
  top: 10rpx;
  height: 1rpx;
  background: rgba(255, 255, 255, 0.48);
}

.save-button-text {
  position: relative;
  z-index: 1;
  color: #ffffff;
  font-size: 29rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}
